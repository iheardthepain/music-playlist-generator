  '寫': '写', '聽': '听', '聲': '声', '響': '响', '飛': '飞', '機': '机',
  '雲': '云', '電': '电', '龍': '龙', '鳳': '凤', '馬': '马', '魚': '鱼',
  '鳥': '鸟', '雞': '鸡', '貓': '猫', '狗': '狗', '蘭': '兰', '菊': '菊',
  '陳': '陈', '張': '张', '劉': '刘', '黃': '黄', '楊': '杨', '趙': '赵',
  '鄭': '郑', '謝': '谢', '許': '许', '鄧': '邓', '蕭': '萧', '葉': '叶',
  '羅': '罗', '韓': '韩', '馮': '冯', '蔡': '蔡', '彭': '彭', '潘': '潘',
  '蘇': '苏', '盧': '卢', '蔣': '蒋', '魏': '魏', '譚': '谭', '鍾': '钟',
  '薛': '薛', '賴': '赖', '鄒': '邹', '範': '范', '廖': '廖', '曾': '曾',
  '費': '费', '萬': '万', '歲': '岁', '齊': '齐', '齡': '龄', '靈': '灵'
};

function normalizeArtistName(name) {
  let result = cleanMatchText(name);
  // 简繁体转换
  for (const [trad, simp] of Object.entries(SIMPLIFIED_MAP)) {
    result = result.replace(new RegExp(trad, 'g'), simp);
  }
  // 提取主要艺术家（处理 "艺术家1、艺术家2" 或 "艺术家1/艺术家2" 格式）
  result = result.split(/[、,\/&]+/)[0].trim();
  return result;
}

function addWeightedTerms(map, terms, weight) {
  for (const term of terms || []) {
    if (!term) continue;
    const key = term.trim();
    if (!key) continue;
    map.set(key, Math.max(map.get(key) || 0, weight));
  }
}

function extractThemeTokens(theme) {
  const tokens = new Set();
  const cleaned = theme.replace(/[：:]/g, ' ').trim();

  cleaned.split(/[\s,，、/|]+/).forEach(token => {
    const value = token.trim();
    if (value) tokens.add(value);
  });

  const chineseParts = cleaned.match(/[\u4e00-\u9fa5]{2,}/g) || [];
  for (const part of chineseParts) {
    const normalized = part.replace(/的/g, '');
    if (normalized.length >= 2) tokens.add(normalized);
  }

  return Array.from(tokens);
}

function buildThemeProfile(theme) {
  const profile = {
    keywords: new Map(),
    artistHints: new Map(),
    exactPhrases: new Map(),
    conceptGroups: [],
    yearPrefixes: [],
    allowSpoken: false,
    requireWestern: false
  };

  addWeightedTerms(profile.exactPhrases, [theme], 12);

  const tokens = extractThemeTokens(theme);
  addWeightedTerms(profile.keywords, tokens.filter(token => token.length >= 2), 3);

  for (const rule of SEMANTIC_THEME_RULES) {
    if (rule.triggers.some(trigger => theme.includes(trigger))) {
      for (const group of rule.concepts || []) {
        profile.conceptGroups.push(group);
        addWeightedTerms(profile.keywords, group, 6);
      }
      addWeightedTerms(profile.artistHints, rule.artists, 7);
      profile.yearPrefixes.push(...(rule.yearPrefixes || []));
      if (rule.allowSpoken) profile.allowSpoken = true;
    }
  }

  if (/\b80s\b|80年代|80后|八十年代|八零/i.test(theme)) {
    profile.conceptGroups.push(['八十年代', '80年代', '80s', '80后']);
    profile.yearPrefixes.push('198');
    addWeightedTerms(profile.artistHints, ['邓丽君', '张学友', '谭咏麟', '梅艳芳', '张国荣', '蔡琴', '李宗盛'], 7);
  }
  if (/\b90s\b|90年代|90后|九十年代|九零/i.test(theme)) {
    profile.conceptGroups.push(['九十年代', '90年代', '90s', '90后']);
    profile.yearPrefixes.push('199');
    addWeightedTerms(profile.artistHints, ['王菲', '陈奕迅', '张惠妹', '林忆莲', 'Beyond', '莫文蔚', '郑秀文'], 7);
  }

  if (/欧美|英文|西洋|western|english|euro|us[-\s]?uk|欧美流行/i.test(theme)) {
    profile.requireWestern = true;
    profile.conceptGroups.push(['欧美', '西洋', '英文', 'western', 'english']);
    addWeightedTerms(profile.keywords, ['欧美', '西洋', '英文', 'western', 'english', 'pop'], 10);
    addWeightedTerms(profile.artistHints, ['Taylor Swift', 'Adele', 'Coldplay', 'Maroon 5', 'Bruno Mars', 'Ed Sheeran', 'Lady Gaga', 'Katy Perry', 'Billie Eilish', 'Michael Jackson'], 12);
  }

  return profile;
}

function extractYearFromText(text) {
  const value = (text || '').toString();
  if (!value) return null;
  const match = value.match(/(?:19|20)\d{2}/);
  if (!match) return null;
  const year = parseInt(match[0], 10);
  return Number.isFinite(year) ? year : null;
}

function extractTrackYear(track) {
  const eraYear = extractYearFromText(track.era);
  if (eraYear) return eraYear;
  const titleYear = extractYearFromText(track.title);
  if (titleYear) return titleYear;
  const pathYear = extractYearFromText(track.file_path);
  if (pathYear) return pathYear;
  return null;
}

function parseThemeIntent(theme) {
  const value = (theme || '').toString();
  const intent = {
    yearRange: null,
    requireWestern: false,
    requireChinese: false
  };

  if (/\b80s\b|80年代|八十年代|八零|80后/i.test(value)) {
    intent.yearRange = [1980, 1989];
  } else if (/\b90s\b|90年代|九十年代|九零|90后/i.test(value)) {
    intent.yearRange = [1990, 1999];
  } else if (/00年代|零零年代|\b2000s\b/i.test(value)) {
    intent.yearRange = [2000, 2009];
  }

  if (/欧美|英文|西洋|western|english|euro|us[-\s]?uk/i.test(value)) {
    intent.requireWestern = true;
  }

  if (/华语|中文|国语|粤语|国风|中文歌|华语流行/i.test(value)) {
    intent.requireChinese = true;
  }

  return intent;
}

function isLikelyWesternTrack(track) {
  const fields = getTrackFieldTexts(track);
  const westernTokens = ['english', 'western', '欧美', '西洋', '英文', 'eu', 'us', 'uk', 'latin'];
  const nonWesternTokens = ['中文', '华语', '国语', '粤语', '日语', '韩语', '民歌'];
  const combined = `${fields.language} ${fields.genre} ${fields.era} ${fields.filePath}`;

  if (westernTokens.some(token => combined.includes(token))) {
    return true;
  }
  if (nonWesternTokens.some(token => combined.includes(token))) {
    return false;
  }

  const artist = (track.artist || '').toString();
  const title = (track.title || '').toString();
  const hasCjk = /[\u4e00-\u9fa5]/.test(`${artist}${title}`);
  return !hasCjk;
}

function isLikelyChineseTrack(track) {
  const fields = getTrackFieldTexts(track);
  const chineseTokens = ['中文', '华语', '国语', '粤语', 'mandarin', 'cantonese'];
  const westernTokens = ['english', 'western', '欧美', '西洋'];
  const combined = `${fields.language} ${fields.genre} ${fields.era} ${fields.filePath}`;

  if (chineseTokens.some(token => combined.includes(token))) {
    return true;
  }
  if (westernTokens.some(token => combined.includes(token))) {
    return false;
  }

  const artist = (track.artist || '').toString();
  const title = (track.title || '').toString();
  return /[\u4e00-\u9fa5]/.test(`${artist}${title}`);
}

function getTrackFieldTexts(track) {
  return {
    title: cleanMatchText(track.title),
    artist: cleanMatchText(track.artist),
    genre: cleanMatchText(track.genre),
    mood: cleanMatchText(track.mood),
    era: cleanMatchText(track.era),
    language: cleanMatchText(track.language),
    notes: cleanMatchText(track.notes),
    filePath: cleanMatchText(track.file_path)
  };
}

function scoreTrackAgainstTheme(track, profile) {
  const fields = getTrackFieldTexts(track);
  let score = 0;
  let matchedConceptGroups = 0;
  const combinedText = `${fields.title} ${fields.artist} ${fields.genre} ${fields.mood} ${fields.era} ${fields.language} ${fields.notes} ${fields.filePath}`;

  if (!profile.allowSpoken && fields.genre === 'spoken-comedy') {
    score -= 300;
  }
  if (profile.allowSpoken && fields.genre === 'spoken-comedy') {
    score += 120;
  }

  if (profile.requireWestern) {
    if (isLikelyWesternTrack(track)) {
      score += 180;
    } else {
      score -= 220;
    }
  }

  for (const [phrase, weight] of profile.exactPhrases.entries()) {
    const term = cleanMatchText(phrase);
    if (!term) continue;
    if (fields.title.includes(term)) score += weight * 30;
    if (fields.artist.includes(term)) score += weight * 28;
    if (fields.genre.includes(term)) score += weight * 20;
    if (fields.filePath.includes(term)) score += weight * 16;
    if (fields.notes.includes(term)) score += weight * 12;
  }

  for (const group of profile.conceptGroups) {
    if (group.some(term => combinedText.includes(cleanMatchText(term)))) {
      matchedConceptGroups += 1;
      score += 30;
    }
  }

  for (const [keyword, weight] of profile.keywords.entries()) {
    const term = cleanMatchText(keyword);
    if (!term || term.length < 2) continue;
    if (fields.title.includes(term)) score += weight * 10;
    if (fields.artist.includes(term)) score += weight * 9;
    if (fields.genre.includes(term)) score += weight * 8;
    if (fields.mood.includes(term)) score += weight * 8;
    if (fields.era.includes(term)) score += weight * 8;
    if (fields.language.includes(term)) score += weight * 6;
    if (fields.filePath.includes(term)) score += weight * 5;
    if (fields.notes.includes(term)) score += weight * 4;
  }

  for (const prefix of profile.yearPrefixes) {
    if (fields.title.includes(prefix) || fields.filePath.includes(prefix)) {
      score += 50;
    }
  }

  for (const [artistHint, weight] of profile.artistHints.entries()) {
    const term = cleanMatchText(artistHint);
    if (!term) continue;
    if (fields.artist.includes(term)) score += weight * 16;
    if (fields.filePath.includes(term)) score += weight * 6;
  }

  if (matchedConceptGroups >= 2) {
    score += matchedConceptGroups * 20;
  }

  if (profile.conceptGroups.length >= 2 && matchedConceptGroups === 0) {
    score -= 40;
  }

  return score;
}

function buildTrackKey(track) {
  const artist = cleanMatchText(track.artist);
  const title = cleanMatchText(track.title);
  return `${artist}::${title}`;
}

// 去重函数：同名歌曲去重 + 同一艺术家最多2首
function deduplicateTracks(rows, count) {
  const selected = [];
  const seen = new Set();
  const seenTitles = new Set();
  const artistCount = new Map();
  const MAX_ARTIST_SONGS = 2;

  for (const track of rows) {
    const key = buildTrackKey(track);
    if (seen.has(key)) continue;
    
    const titleKey = cleanMatchText(track.title);
    if (seenTitles.has(titleKey)) continue;
    
    const artist = normalizeArtistName(track.artist);
    const currentCount = artistCount.get(artist) || 0;
    if (currentCount >= MAX_ARTIST_SONGS) continue;
    
    seen.add(key);
    seenTitles.add(titleKey);
    artistCount.set(artist, currentCount + 1);
    selected.push(track);
    if (selected.length >= count) break;
  }
  
  return selected;
}

function selectTracksForTheme(rows, theme, count) {
  const profile = buildThemeProfile(theme);
  const intent = parseThemeIntent(theme);
  const ranked = rows
    .map(track => ({ track, score: scoreTrackAgainstTheme(track, profile) }))
    .sort((a, b) => b.score - a.score || Math.random() - 0.5);

  const positiveRanked = ranked.filter(item => item.score > 0);
  let source = positiveRanked.length > 0 ? positiveRanked : ranked;

  if (profile.requireWestern) {
    const westernOnly = source.filter(item => isLikelyWesternTrack(item.track));
    if (westernOnly.length > 0) {
      source = westernOnly;
    }
  }

  if (intent.requireChinese && !intent.requireWestern) {
    const chineseOnly = source.filter(item => isLikelyChineseTrack(item.track));
    if (chineseOnly.length > 0) {
      source = chineseOnly;
    }
  }

  if (intent.yearRange) {
    const [startYear, endYear] = intent.yearRange;
    const yearMatched = source.filter(item => {
      const year = extractTrackYear(item.track);
      return year !== null && year >= startYear && year <= endYear;
    });

    const minimumAcceptable = Math.max(5, Math.floor(count * 0.4));
    if (yearMatched.length >= minimumAcceptable) {
      source = yearMatched;
    }
  }

  const selected = [];
  const seen = new Set();
  const seenTitles = new Set(); // 同名歌曲去重（不管艺术家）
  const artistCount = new Map(); // 统计每个艺术家已有几首歌
  const MAX_ARTIST_SONGS = 2; // 同一个艺术家最多两首歌，除非用户特别指定

  for (const item of source) {
    if (!profile.allowSpoken && cleanMatchText(item.track.genre) === 'spoken-comedy') {
      continue;
    }

    const key = buildTrackKey(item.track);
    if (seen.has(key)) continue;
    
    // 检查同名歌曲（不管艺术家）
    const titleKey = cleanMatchText(item.track.title);
    if (seenTitles.has(titleKey)) continue;
    
    // 检查同一个艺术家数量限制（简繁体统一）
    const artist = normalizeArtistName(item.track.artist);
    const currentCount = artistCount.get(artist) || 0;
    if (currentCount >= MAX_ARTIST_SONGS) continue;
    
    seen.add(key);
    seenTitles.add(titleKey);
    artistCount.set(artist, currentCount + 1);
    selected.push(item.track);
    if (selected.length >= count) break;
  }

  if (selected.length < count) {
    for (const item of ranked) {
      const key = buildTrackKey(item.track);
      if (seen.has(key)) continue;
      
      const titleKey = cleanMatchText(item.track.title);
      if (seenTitles.has(titleKey)) continue;
      
      const artist = normalizeArtistName(item.track.artist);
      const currentCount = artistCount.get(artist) || 0;
      if (currentCount >= MAX_ARTIST_SONGS) continue;
      
      seen.add(key);
      seenTitles.add(titleKey);
      artistCount.set(artist, currentCount + 1);
      selected.push(item.track);
      if (selected.length >= count) break;
    }
  }

  return selected;
}

async function generatePlaylist(theme, count = DEFAULT_PLAYLIST_COUNT) {
  const safeCount = normalizePlaylistCount(count);
  await ensureWebServerReady();

  // 检查缓存
  const cached = getCachedPlaylist(theme);
  if (cached) {
    const cachedTracks = Array.isArray(cached.tracks) ? cached.tracks : [];
    return {
      success: true,
      message: buildPlaylistMessage(theme, cachedTracks, cached.playlistUrl, true),
      playlistUrl: cached.playlistUrl,
      playlistIntro: buildPlaylistIntro(theme, cachedTracks),
      playlistSummaryTable: buildPlaylistSummaryTable(cachedTracks),
      cached: true
    };
  }

  return new Promise((resolve, reject) => {
    const db = new sqlite3.Database(DB_PATH);
    
    // 搜索匹配主题的歌曲
    let sql, params;
    if (theme.toLowerCase() === 'random') {
      sql = `SELECT * FROM tracks ORDER BY RANDOM() LIMIT ?`;
      params = [safeCount];
    } else {
      sql = `SELECT * FROM tracks`;
      params = [];
    }

    db.all(sql, params, (err, rows) => {
      if (err) {
        db.close();
        return resolve({ success: false, message: `❌ 数据库错误: ${err.message}`, playlistUrl: '' });
      }

      if (!rows || rows.length === 0) {
        db.close();
        return resolve({ 
          success: false, 
          message: `😅 没有找到「${theme}」相关的歌曲\n💡 试试：流行、古典、周杰伦、random`, 
          playlistUrl: '' 
        });
      }

      if (theme.toLowerCase() !== 'random') {
        rows = selectTracksForTheme(rows, theme, safeCount);
      } else {
        // random 主题也需要去重
        rows = deduplicateTracks(rows, safeCount);
      }

      // 加载艺术家元数据
      const artistData = loadArtistMetadata();
      const artistMap = {};
      artistData.forEach(item => { artistMap[item.artist] = item.metadata; });

      // 加载歌词
      const trackIds = rows.map(r => r.id).filter(Boolean);
      const lyricsMap = {};
      
      const loadLyricsAndGenerate = () => {
        // 生成HTML
        const fileName = `${theme.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5]/gi, '-')}-${Date.now()}.html`;
        const html = generateVinylHtml(theme, rows, artistMap, lyricsMap);
        
        // 保存文件
        fs.mkdirSync(OUTPUT_DIR, { recursive: true });
        fs.mkdirSync(PUBLIC_DIR, { recursive: true });
        const outputPath = path.join(OUTPUT_DIR, fileName);
        const publicPath = path.join(PUBLIC_DIR, fileName);
        fs.writeFileSync(outputPath, html, 'utf8');
        fs.writeFileSync(publicPath, html, 'utf8');

        // 创建桌面快捷方式
        createDesktopShortcut(outputPath);

        const playlistUrl = `${BASE_URL}/playlists/${encodeURIComponent(fileName)}`;
        
        // 缓存
        cachePlaylist(theme, { tracks: rows, playlistUrl, theme });

        db.close();
        resolve({
          success: true,
          message: buildPlaylistMessage(theme, rows, playlistUrl, false),
          playlistUrl,
          playlistIntro: buildPlaylistIntro(theme, rows),
          playlistSummaryTable: buildPlaylistSummaryTable(rows),
          cached: false
        });
      };

      if (trackIds.length > 0) {
        db.all(`SELECT track_id, lyrics FROM lyrics WHERE track_id IN (${trackIds.join(',')})`, [], (err, lyricsRows) => {
          if (!err && lyricsRows) {
            lyricsRows.forEach(row => { lyricsMap[row.track_id] = row.lyrics; });
          }
          loadLyricsAndGenerate();
        });
      } else {
        loadLyricsAndGenerate();
      }
    });
  });
}

// 创建桌面快捷方式
function createDesktopShortcut(targetPath) {
  try {
    const desktopPath = path.join(process.env.USERPROFILE || require('os').homedir(), 'Desktop', '我的最新歌单.url');
    const urlContent = `[InternetShortcut]\nURL=file:///${targetPath.replace(/\\/g, '/')}\n`;
    fs.writeFileSync(desktopPath, urlContent, 'utf8');
  } catch (e) {
    console.warn('创建快捷方式失败:', e.message);
  }
}

// 生成传统黑胶唱片风格HTML
function generateVinylHtml(theme, tracks, artistMetadata, lyricsMap) {
  const style = getThemeStyle(theme);
  const musicRoot = 'YOUR_MUSIC_PROJECT_DIR';
  
  // 找一个有封面的歌曲作为主封面
  let mainCover = '';
  for (const track of tracks) {
    const cover = findCoverArt(track.file_path);
    if (cover) {
      mainCover = BASE_URL + '/cover?path=' + encodeURIComponent(cover);
      break;
    }
  }

  // 格式化文件大小显示
  const formatFileSize = (bytes) => {
    if (!bytes || bytes === 0) return '';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  };

  const trackListHtml = tracks.map((track, i) => {
    const cover = findCoverArt(track.file_path);
    let coverUrl = '';
    if (cover) {
      coverUrl = BASE_URL + '/cover?path=' + encodeURIComponent(cover);
    }
    
    // 使用 /play?path= 路由，服务器会用ffmpeg转码播放
    const audioUrl = BASE_URL + '/play?path=' + encodeURIComponent(track.file_path);

    const artist = track.artist || '未知艺术家';
    const title = track.title || '未知标题';
    const aInfo = artistMetadata[artist];
    const bio = aInfo && aInfo.description ? aInfo.description : '';
    const lyrics = lyricsMap[track.id] || '';
    const fileSize = formatFileSize(track.file_size);

    return `
    <div class="track" data-audio="${audioUrl}" data-cover="${coverUrl}">
      <div class="track-num">${String(i + 1).padStart(2, '0')}</div>
      <div class="track-info">
        <div class="track-title">${title}</div>
        <div class="track-artist">${artist} ${fileSize ? `<span class="file-size">• ${fileSize}</span>` : ''}</div>
      </div>
      <div class="track-duration">♪</div>
      ${bio ? `<div class="track-bio hidden">${bio}</div>` : ''}
      ${lyrics ? `<div class="track-lyrics hidden">${lyrics}</div>` : ''}
    </div>`;
  }).join('\n');

  // 收集所有封面URL用于预加载
  const allCovers = new Set();
  if (mainCover) allCovers.add(mainCover);
  tracks.forEach(track => {
    const cover = findCoverArt(track.file_path);
    if (cover) {
      allCovers.add(BASE_URL + '/cover?path=' + encodeURIComponent(cover));
    }
  });
  const preloadLinks = Array.from(allCovers).map(url => 
    `<link rel="preload" as="image" href="${url}">`
  ).join('\n');

  return `<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>${theme} - 私人唱片</title>
${preloadLinks}
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: ${style.bg};
  color: ${style.text};
  min-height: 100vh;
}

/* 唱片封面区域 */
.album-cover {
  position: relative;
  width: 100%;
  max-width: 500px;
  margin: 0 auto;
  padding: 40px 20px;
}

.vinyl-container {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
}

.vinyl-record {
  position: absolute;
  width: 90%;
  height: 90%;
  right: 0;
  top: 5%;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, 
    #1a1a1a 0%, #1a1a1a 15%, 
    #333 15.5%, #222 16%, 
    #333 25%, #222 25.5%,
    #333 35%, #222 35.5%,
    #333 45%, #1a1a1a 46%,
    #1a1a1a 100%);
  box-shadow: 0 0 30px rgba(0,0,0,0.5);
  animation: spin 8s linear infinite paused;
}

.vinyl-record.playing { animation-play-state: running; }

.vinyl-label {
  position: absolute;
  width: 35%;
  height: 35%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: ${style.accent};
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 0.8em;
  text-align: center;
  color: ${style.bg};
  padding: 10px;
  overflow: hidden;
}

.vinyl-label .label-title {
  font-size: 0.7em;
  font-weight: bold;
  margin-bottom: 2px;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vinyl-label .label-artist {
  font-size: 0.6em;
  opacity: 0.8;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cover-sleeve {
  position: absolute;
  width: 85%;
  height: 85%;
  left: 0;
  top: 7.5%;
  background: ${mainCover ? `url("${mainCover}") center/cover` : style.accent};
  border-radius: 8px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  z-index: 2;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30px 20px;
  background: linear-gradient(transparent, rgba(0,0,0,0.9));
  border-radius: 0 0 8px 8px;
}

.album-title {
  font-size: 2em;
  font-weight: 700;
  margin-bottom: 8px;
  color: #fff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}

.album-meta {
  font-size: 0.95em;
  opacity: 0.9;
  color: ${style.accent};
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 播放器控制 */
.player-bar {
  background: rgba(0,0,0,0.8);
  backdrop-filter: blur(20px);
  padding: 15px 20px;
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 15px;
}

.now-playing {
  flex: 1;
  min-width: 0;
}

.now-playing-title {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.now-playing-artist {
  font-size: 0.85em;
  opacity: 0.7;
}

.play-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: ${style.accent};
  border: none;
  color: ${style.bg};
  font-size: 1.5em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.play-btn:hover { transform: scale(1.1); }

.progress-bar {
  flex: 2;
  height: 6px;
  background: rgba(255,255,255,0.2);
  border-radius: 3px;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: ${style.accent};
  border-radius: 3px;
  width: 0%;
  transition: width 0.1s;
}

/* 曲目列表 */
.track-list {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
}

.section-title {
  font-size: 1.2em;
  color: ${style.accent};
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 2px solid ${style.accent};
}

.track {
  display: flex;
  align-items: center;
  padding: 15px;
  border-radius: 10px;
  cursor: pointer;
  transition: background 0.2s;
  gap: 15px;
}

.track:hover, .track.active {
  background: rgba(255,255,255,0.1);
}

.track.active {
  border-left: 3px solid ${style.accent};
}

.track-num {
  font-size: 0.9em;
  opacity: 0.5;
  width: 30px;
}

.track-info { flex: 1; min-width: 0; }

.track-title {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-artist {
  font-size: 0.85em;
  opacity: 0.7;
  margin-top: 2px;
}

.file-size {
  font-size: 0.8em;
  opacity: 0.5;
}

.track-duration {
  opacity: 0.5;
}

.hidden { display: none; }

/* 歌词弹窗 */
.lyrics-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  z-index: 200;
  overflow-y: auto;
  padding: 60px 20px;
}

.lyrics-modal.show { display: block; }

.lyrics-content {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  line-height: 2;
  font-size: 1.1em;
  white-space: pre-wrap;
}

.lyrics-close {
  position: fixed;
  top: 20px;
  right: 20px;
  background: none;
  border: none;
  color: #fff;
  font-size: 2em;
  cursor: pointer;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 40px;
  opacity: 0.5;
  font-size: 0.9em;
}

@media (max-width: 600px) {
  .album-cover { padding: 20px 10px; }
  .album-title { font-size: 1.5em; }
  .player-bar { flex-wrap: wrap; }
  .progress-bar { order: 3; flex-basis: 100%; margin-top: 10px; }
}
</style>
</head>
<body>

<div class="album-cover">
  <div class="vinyl-container">
    <div class="vinyl-record" id="vinyl">
      <div class="vinyl-label">${theme}</div>
    </div>
    <div class="cover-sleeve">
      <div class="cover-overlay">
        <div class="album-title">${theme}</div>
        <div class="album-meta">${tracks.length} 首歌曲 · ${style.vibe}</div>
      </div>
    </div>
  </div>
</div>

<div class="player-bar">
  <button class="play-btn" id="playBtn">▶</button>
  <div class="now-playing">
    <div class="now-playing-title" id="nowTitle">选择一首歌曲</div>
    <div class="now-playing-artist" id="nowArtist">-</div>
  </div>
  <div class="progress-bar" id="progressBar">
    <div class="progress-fill" id="progressFill"></div>
  </div>
</div>

<div class="track-list">
  <div class="section-title">🎵 曲目列表</div>
  ${trackListHtml}
</div>

<div class="lyrics-modal" id="lyricsModal">
  <button class="lyrics-close" onclick="closeLyrics()">×</button>
  <div class="lyrics-content" id="lyricsContent"></div>
</div>

<div class="footer">
  🎵 私人音乐库 · ${new Date().toLocaleDateString('zh-CN')}
</div>

<audio id="audioPlayer"></audio>

<script>
// ========== 播放器核心 ==========
const audio = document.getElementById('audioPlayer');
const playBtn = document.getElementById('playBtn');
const vinyl = document.getElementById('vinyl');
const nowTitle = document.getElementById('nowTitle');
const nowArtist = document.getElementById('nowArtist');
const progressBar = document.getElementById('progressBar');
const progressFill = document.getElementById('progressFill');
const tracks = document.querySelectorAll('.track');
let currentTrack = null;
let currentBlobUrl = null; // 跟踪当前的 Blob URL 以便释放
const PLAYLIST_ID = location.pathname.split('/').pop().replace('.html','');

// ========== 缓存配置 ==========
let CACHE_NAME = 'music-playlist-v2';
let BROWSER_CACHE_ENABLED = true;
let cacheInitialized = false;

// ========== 缓存进度条UI ==========
function createCacheProgressUI() {
  const container = document.createElement('div');
  container.id = 'cacheProgressContainer';
  container.style.cssText = 'width:100%;max-width:300px;margin:10px auto;padding:0 20px;';
  container.innerHTML = '<div style="display:flex;align-items:center;gap:8px;font-size:0.75em;color:rgba(255,255,255,0.7);"><span id="cacheLabel">准备缓存...</span><span id="cachePercent" style="margin-left:auto;"></span></div><div style="height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin-top:4px;overflow:hidden;"><div id="cacheProgressBar" style="height:100%;background:${style.accent};width:0%;transition:width 0.3s;"></div></div>';
  // 插入到播放按钮下方
  const playerBar = document.querySelector('.player-bar');
  if (playerBar) playerBar.after(container);
}

function updateCacheProgress(cached, total, status) {
  const container = document.getElementById('cacheProgressContainer');
  const bar = document.getElementById('cacheProgressBar');
  const label = document.getElementById('cacheLabel');
  const percent = document.getElementById('cachePercent');
  if (!container) return;
  
  container.style.display = 'block';
  
  if (status === 'complete') {
    label.textContent = '✓ 已缓存';
    bar.style.width = '100%';
    percent.textContent = total + '首';
    setTimeout(() => { container.style.display = 'none'; }, 5000);
  } else if (status === 'checking') {
    label.textContent = '检查缓存...';
    bar.style.width = '0%';
    percent.textContent = '';
  } else if (status === 'unsupported') {
    label.textContent = '⚠ 浏览器不支持离线缓存';
    bar.style.width = '0%';
    percent.textContent = '';
    setTimeout(() => { container.style.display = 'none'; }, 5000);
  } else if (status === 'disabled') {
    label.textContent = '离线缓存已禁用';
    bar.style.width = '0%';
    percent.textContent = '';
    setTimeout(() => { container.style.display = 'none'; }, 3000);
  } else {
    const pct = total > 0 ? Math.round(cached / total * 100) : 0;
    label.textContent = '缓存中 ' + cached + '/' + total;
    bar.style.width = pct + '%';
    percent.textContent = pct + '%';
  }
}

// ========== 播放状态持久化 ==========
function savePlayState() {
  if (currentTrack === null) return;
  const state = { track: currentTrack, time: audio.currentTime, playlist: PLAYLIST_ID };
  try { localStorage.setItem('playState_' + PLAYLIST_ID, JSON.stringify(state)); } catch(e) {}
}

function loadPlayState() {
  try {
    const raw = localStorage.getItem('playState_' + PLAYLIST_ID);
    if (raw) return JSON.parse(raw);
  } catch(e) {}
  return null;
}

function clearPlayState() {
  try { localStorage.removeItem('playState_' + PLAYLIST_ID); } catch(e) {}
}

// ========== Media Session API (锁屏控制) ==========
function updateMediaSession(title, artist, coverUrl) {
  if (!('mediaSession' in navigator)) return;
  const artwork = coverUrl && coverUrl.trim() ? [{ src: coverUrl, sizes: '512x512', type: 'image/jpeg' }] : [];
  navigator.mediaSession.metadata = new MediaMetadata({ title, artist, album: '${theme}', artwork });
  navigator.mediaSession.setActionHandler('play', () => audio.play());
  navigator.mediaSession.setActionHandler('pause', () => audio.pause());
  navigator.mediaSession.setActionHandler('previoustrack', playPrev);
  navigator.mediaSession.setActionHandler('nexttrack', playNext);
  navigator.mediaSession.setActionHandler('seekbackward', () => { audio.currentTime = Math.max(0, audio.currentTime - 10); });
  navigator.mediaSession.setActionHandler('seekforward', () => { audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 10); });
}

// ========== 核心播放函数 ==========
async function playTrack(track, index, seekTime) {
  const audioUrl = track.dataset.audio;
  const coverUrl = track.dataset.cover;
  const title = track.querySelector('.track-title').textContent;
  const artist = track.querySelector('.track-artist').textContent;
  
  tracks.forEach(t => t.classList.remove('active'));
  track.classList.add('active');
  track.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  
  nowTitle.textContent = title;
  nowArtist.textContent = artist;
  
  const coverSleeve = document.querySelector('.cover-sleeve');
  const vinylLabel = document.querySelector('.vinyl-label');
  
  if (coverUrl && coverUrl.trim() !== '') {
    coverSleeve.style.display = 'block';
    coverSleeve.style.backgroundImage = 'url("' + coverUrl + '")';
    vinylLabel.innerHTML = '${theme}';
  } else {
    coverSleeve.style.display = 'none';
    vinylLabel.innerHTML = '<div class="label-title">' + title + '</div><div class="label-artist">' + artist + '</div>';
  }
  
  // 释放之前的 Blob URL
  if (currentBlobUrl) { URL.revokeObjectURL(currentBlobUrl); currentBlobUrl = null; }
  
  // 优先从缓存读取
  const resolvedUrl = await playFromCacheOrNetwork(audioUrl);
  if (resolvedUrl !== audioUrl) currentBlobUrl = resolvedUrl;
  
  audio.src = resolvedUrl;
  if (typeof seekTime === 'number' && seekTime > 0) {
    audio.currentTime = seekTime;
  }
  
  try { await audio.play(); } catch(e) { console.warn('播放失败:', e); }
  currentTrack = index;
  
  updateMediaSession(title, artist, coverUrl);
  savePlayState();
}

function playNext() {
  if (currentTrack !== null && currentTrack < tracks.length - 1) {
    playTrack(tracks[currentTrack + 1], currentTrack + 1);
  }
}

function playPrev() {
  if (currentTrack !== null && currentTrack > 0) {
    playTrack(tracks[currentTrack - 1], currentTrack - 1);
  }
}

// ========== 事件绑定 ==========
tracks.forEach((track, index) => {
  track.addEventListener('click', () => playTrack(track, index));
  track.addEventListener('dblclick', () => {
    const lyrics = track.querySelector('.track-lyrics');
    if (lyrics) showLyrics(lyrics.textContent);
  });
});

playBtn.addEventListener('click', () => {
  if (audio.paused) {
    if (!audio.src && tracks.length > 0) {
      playTrack(tracks[0], 0);
    } else {
      audio.play();
    }
  } else {
    audio.pause();
  }
});

audio.addEventListener('play', () => {
  playBtn.textContent = '⏸';
  vinyl.classList.add('playing');
  requestAnimationFrame(updateProgress);
});

audio.addEventListener('pause', () => {
  playBtn.textContent = '▶';
  vinyl.classList.remove('playing');
  savePlayState();
});

audio.addEventListener('timeupdate', () => {
  updateProgress();
  // 每10秒保存一次播放位置
  if (Math.floor(audio.currentTime) % 10 === 0) savePlayState();
});

// 播放结束 -> 自动下一首
audio.addEventListener('ended', () => {
  clearPlayState();
  playNext();
});

// 错误处理和重试
let retryCount = 0;
const MAX_RETRIES = 3;
audio.addEventListener('error', (e) => {
  console.warn('音频错误:', e);
  if (retryCount < MAX_RETRIES && currentTrack !== null) {
    retryCount++;
    console.log('重试播放 (' + retryCount + '/' + MAX_RETRIES + ')');
    setTimeout(() => {
      audio.load();
      audio.play().catch(() => {});
    }, 1000 * retryCount);
  } else {
    // 重试失败，跳到下一首
    retryCount = 0;
    playNext();
  }
});

audio.addEventListener('canplay', () => { retryCount = 0; });

// 网络恢复时尝试继续播放
window.addEventListener('online', () => {
  if (audio.paused && audio.src && audio.currentTime > 0) {
    audio.play().catch(() => {});
  }
});

// 页面可见性变化 - 防止后台暂停
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible' && !audio.paused) {
    // 页面重新可见时确保继续播放
    audio.play().catch(() => {});
  }
});

function updateProgress() {
  if (audio.duration) {
    const percent = (audio.currentTime / audio.duration * 100);
    progressFill.style.width = percent + '%';
  }
}

// 进度条点击跳转
progressBar.addEventListener('click', (e) => {
  if (!audio.duration) return;
  const rect = progressBar.getBoundingClientRect();
  const percent = (e.clientX - rect.left) / rect.width;
  audio.currentTime = percent * audio.duration;
});

function showLyrics(text) {
  document.getElementById('lyricsContent').textContent = text;
  document.getElementById('lyricsModal').classList.add('show');
}

function closeLyrics() {
  document.getElementById('lyricsModal').classList.remove('show');
}

// ========== 缓存功能 ==========
// 支持 Cache API 和 IndexedDB 两种方式
let cacheMode = 'none'; // 'cache-api', 'indexeddb', 'none'
let idb = null;
const IDB_NAME = 'music-cache';
const IDB_STORE = 'audio';

function supportsCacheAPI() {
  // Cache API 需要安全上下文 (HTTPS 或 localhost)
  const isSecure = location.protocol === 'https:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1';
  return isSecure && 'caches' in window;
}

function supportsIndexedDB() {
  return 'indexedDB' in window;
}

// 初始化 IndexedDB
function initIndexedDB() {
  return new Promise((resolve, reject) => {
    const request = indexedDB.open(IDB_NAME, 1);
    request.onerror = () => reject(request.error);
    request.onsuccess = () => { idb = request.result; resolve(idb); };
    request.onupgradeneeded = (e) => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(IDB_STORE)) {
        db.createObjectStore(IDB_STORE);
      }
    };
  });
}

// IndexedDB 读取
function idbGet(key) {
  return new Promise((resolve, reject) => {
    if (!idb) { resolve(null); return; }
    const tx = idb.transaction(IDB_STORE, 'readonly');
    const req = tx.objectStore(IDB_STORE).get(key);
    req.onsuccess = () => resolve(req.result);
    req.onerror = () => resolve(null);
  });
}

// IndexedDB 写入
function idbPut(key, value) {
  return new Promise((resolve, reject) => {
    if (!idb) { resolve(false); return; }
    const tx = idb.transaction(IDB_STORE, 'readwrite');
    const req = tx.objectStore(IDB_STORE).put(value, key);
    req.onsuccess = () => resolve(true);
    req.onerror = () => resolve(false);
  });
}

function getAllTrackUrls() {
  return Array.from(tracks).map(track => track.dataset.audio).filter(Boolean);
}

async function playFromCacheOrNetwork(audioUrl) {
  if (!BROWSER_CACHE_ENABLED || cacheMode === 'none') return audioUrl;
  
  try {
    if (cacheMode === 'cache-api') {
      const cache = await caches.open(CACHE_NAME);
      const cached = await cache.match(audioUrl);
      if (cached) {
        const blob = await cached.blob();
        return URL.createObjectURL(blob);
      }
    } else if (cacheMode === 'indexeddb') {
      const blob = await idbGet(audioUrl);
      if (blob) {
        return URL.createObjectURL(blob);
      }
    }
  } catch (e) {}
  return audioUrl;
}

async function cacheAllTracks() {
  const urls = getAllTrackUrls();
  if (!urls.length) return;
  
  updateCacheProgress(0, urls.length, 'checking');
  
  const uncached = [];
  let cachedCount = 0;
  
  // 检查已缓存的文件
  for (const url of urls) {
    let hit = false;
    try {
      if (cacheMode === 'cache-api') {
        const cache = await caches.open(CACHE_NAME);
        hit = !!(await cache.match(url));
      } else if (cacheMode === 'indexeddb') {
        hit = !!(await idbGet(url));
      }
    } catch (e) {}
    
    if (hit) cachedCount++;
    else uncached.push(url);
  }
  
  if (uncached.length === 0) {
    updateCacheProgress(urls.length, urls.length, 'complete');
    return;
  }
  
  updateCacheProgress(cachedCount, urls.length, 'caching');
  
  // 并行下载（最多3个同时）
  const PARALLEL = 3;
  const cacheOne = async (url) => {
    try {
      const resp = await fetch(url);
      if (resp.ok) {
        if (cacheMode === 'cache-api') {
          const cache = await caches.open(CACHE_NAME);
          await cache.put(url, resp);
        } else if (cacheMode === 'indexeddb') {
          const blob = await resp.blob();
          await idbPut(url, blob);
        }
        cachedCount++;
        updateCacheProgress(cachedCount, urls.length, 'caching');
      }
    } catch (e) {}
  };
  
  // 分批并行处理
  for (let i = 0; i < uncached.length; i += PARALLEL) {
    const batch = uncached.slice(i, i + PARALLEL);
    await Promise.all(batch.map(cacheOne));
  }
  
  updateCacheProgress(cachedCount, urls.length, 'complete');
}

// 初始化缓存系统
async function initCacheSystem() {
  // 先尝试 Cache API
  if (supportsCacheAPI()) {
    try {
      const testCache = await caches.open(CACHE_NAME);
      if (testCache) {
        cacheMode = 'cache-api';
        console.log('缓存模式: Cache API');
        return true;
      }
    } catch (e) {
      console.warn('Cache API 不可用:', e);
    }
  }
  
  // 再尝试 IndexedDB
  if (supportsIndexedDB()) {
    try {
      await initIndexedDB();
      cacheMode = 'indexeddb';
      console.log('缓存模式: IndexedDB');
      return true;
    } catch (e) {
      console.warn('IndexedDB 不可用:', e);
    }
  }
  
  cacheMode = 'none';
  console.log('缓存模式: 无');
  return false;
}

// ========== 初始化 ==========
(async function init() {
  createCacheProgressUI();
  
  // 加载缓存配置
  try {
    const resp = await fetch('/api/local-cache-config');
    if (resp.ok) {
      const cfg = await resp.json();
      BROWSER_CACHE_ENABLED = cfg.enabled !== false;
      CACHE_NAME = cfg.cacheName || 'music-playlist-v2';
    }
  } catch (e) {}
  
  // 恢复播放状态
  const savedState = loadPlayState();
  if (savedState && savedState.track < tracks.length) {
    const resumeBtn = document.createElement('button');
    resumeBtn.textContent = '▶ 继续上次播放';
    resumeBtn.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:${style.accent};color:#1a1a2e;border:none;padding:10px 20px;border-radius:20px;font-size:0.9em;cursor:pointer;z-index:999;box-shadow:0 4px 15px rgba(0,0,0,0.3);';
    resumeBtn.onclick = () => {
      playTrack(tracks[savedState.track], savedState.track, savedState.time);
      resumeBtn.remove();
    };
    document.body.appendChild(resumeBtn);
    setTimeout(() => { if (resumeBtn.parentNode) resumeBtn.remove(); }, 10000);
  }
  
  // 初始化缓存系统
  if (!BROWSER_CACHE_ENABLED) {
    updateCacheProgress(0, 0, 'disabled');
  } else {
    const cacheSupported = await initCacheSystem();
    if (cacheSupported) {
      setTimeout(cacheAllTracks, 1500);
    } else {
      updateCacheProgress(0, 0, 'unsupported');
    }
  }
})();
</script>
</body>
</html>`;
}

// CLI入口
if (require.main === module) {
  let theme = process.argv[2];
  const parsedCount = parseInt(process.argv[3], 10);
  const count = normalizePlaylistCount(parsedCount);
  
  if (!theme || theme.trim() === '') {
    theme = getSmartTheme();
  }
  
  generatePlaylist(theme, count).then(result => {
    console.log(result.message);
  }).catch(e => console.error('致命错误:', e));
}

module.exports = { generatePlaylist, chooseAutoTheme };


