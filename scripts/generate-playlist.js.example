// 智能选择主题（根据时间和星期）
function chooseAutoTheme() {
  const hour = new Date().getHours();
  const day = new Date().getDay();
  const isWeekend = (day === 0 || day === 6);
  
  let timeThemes = [];
  
  if (hour >= 6 && hour < 9) {
    timeThemes = AUTO_THEME_PRESETS.morning;
  } else if (hour >= 9 && hour < 12) {
    timeThemes = AUTO_THEME_PRESETS.work;
  } else if (hour >= 12 && hour < 14) {
    timeThemes = AUTO_THEME_PRESETS.afternoon;
  } else if (hour >= 14 && hour < 18) {
    timeThemes = AUTO_THEME_PRESETS.work;
  } else if (hour >= 18 && hour < 21) {
    timeThemes = AUTO_THEME_PRESETS.evening;
  } else {
    timeThemes = AUTO_THEME_PRESETS.night;
  }
  
  const pool = [...timeThemes];

  if (isWeekend) {
    pool.push(...AUTO_THEME_PRESETS.weekend);
  }

  pool.push(...AUTO_THEME_PRESETS.universal);
  return pool[Math.floor(Math.random() * pool.length)];
}

function getSmartTheme() {
  return chooseAutoTheme();
}

function buildPlaylistIntro(theme, tracks) {
  const safeTracks = Array.isArray(tracks) ? tracks : [];
  const uniqueArtists = new Set(
    safeTracks
      .map(track => (track.artist || '').trim())
      .filter(Boolean)
  );

  const hasSpoken = safeTracks.some(track => cleanMatchText(track.genre) === 'spoken-comedy');
  const mood = hasSpoken ? '轻松逗趣' : '情绪连贯';

  return `这份「${theme}」歌单共 ${safeTracks.length} 首，覆盖 ${uniqueArtists.size} 位艺人，整体氛围偏${mood}，已按主题相关度排序。`;
}

function buildPlaylistSummaryTable(tracks, limit = DEFAULT_SUMMARY_COUNT) {
  const safeTracks = Array.isArray(tracks) ? tracks : [];
  return safeTracks.slice(0, limit).map((track, index) => {
    const title = (track.title || '未知标题').trim();
    const artist = (track.artist || '未知艺术家').trim();
    return `${index + 1}. ${title} - ${artist}`;
  });
}

function shortenText(text, maxLength) {
  const safe = (text || '').trim();
  if (!safe) return '';
  if (safe.length <= maxLength) return safe;
  return `${safe.slice(0, maxLength - 1)}…`;
}

function normalizeDisplayTitle(title) {
  const value = (title || '未知标题').toString().trim();
  return value.replace(/^[a-d]?\d{1,3}[.\-_:：\s]+/i, '').trim() || '未知标题';
}

function normalizeDisplayArtist(artist) {
  return (artist || '未知艺术家').toString().trim() || '未知艺术家';
}

function buildCompactSummaryTable(tracks, limit = MESSAGE_SUMMARY_COUNT) {
  const safeTracks = Array.isArray(tracks) ? tracks : [];
  return safeTracks.slice(0, limit).map((track, index) => {
    const title = shortenText(normalizeDisplayTitle(track.title), 18);
    const artist = shortenText(normalizeDisplayArtist(track.artist), 12);
    return `${index + 1}. ${title} - ${artist}`;
  });
}

function buildPlaylistMessage(theme, tracks, playlistUrl, isCached) {
  const safeTracks = Array.isArray(tracks) ? tracks : [];
  const intro = buildPlaylistIntro(theme, safeTracks);
  const summary = buildCompactSummaryTable(safeTracks);
  const lines = [
    isCached
      ? `🎵 已为你加载缓存的「${theme}」歌单！`
      : `🎵 「${theme}」歌单生成完成！`,
    `🎶 共 ${safeTracks.length} 首歌曲`,
    `🔗 ${playlistUrl}`,
    '',
    `📝 ${intro}`,
    ''
  ];

  if (summary.length > 0) {
    lines.push(`📋 歌单简表（按顺序前${summary.length}首）：`);
    lines.push(...summary);
    if (safeTracks.length > summary.length) {
      lines.push(`… 其余 ${safeTracks.length - summary.length} 首请点链接查看`);
    }
  }

  return lines.join('\n');
}

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function isPortOpen(port, host = '127.0.0.1', timeoutMs = 800) {
  return new Promise(resolve => {
    const socket = new net.Socket();
    let settled = false;

    const done = ok => {
      if (settled) return;
      settled = true;
      try {
        socket.destroy();
      } catch (_) {}
      resolve(ok);
    };

    socket.setTimeout(timeoutMs);
    socket.once('connect', () => done(true));
    socket.once('timeout', () => done(false));
    socket.once('error', () => done(false));

    socket.connect(port, host);
  });
}

async function ensureWebServerReady() {
  const port = config.server?.port || 3000;
  const listening = await isPortOpen(port);
  if (listening) return;

  const serverEntry = path.resolve(__dirname, '../server/index.js');
  const child = spawn(process.execPath, [serverEntry], {
    detached: true,
    stdio: 'ignore',
    windowsHide: true,
    env: process.env
  });
  child.unref();

  for (let attempt = 0; attempt < 20; attempt += 1) {
    await sleep(300);
    if (await isPortOpen(port)) return;
  }

  console.warn('警告: 音乐服务未能及时启动，歌单链接可能暂时不可用。');
}

// 在音乐文件所在目录查找封面图
function findCoverArt(filePath) {
  try {
    const dir = path.dirname(filePath);
    const files = fs.readdirSync(dir);
    const img = files.find(f => /\.(jpg|jpeg|png|gif|bmp|webp)$/i.test(f));
    if (img) return path.join(dir, img);
    const parent = path.dirname(dir);
    const pFiles = fs.readdirSync(parent);
    const pImg = pFiles.find(f => /\.(jpg|jpeg|png|gif|bmp|webp)$/i.test(f));
    if (pImg) return path.join(parent, pImg);
  } catch (_) {}
  return null;
}

// 加载艺术家元数据
function loadArtistMetadata() {
  try {
    if (fs.existsSync(ARTIST_METADATA)) {
      return JSON.parse(fs.readFileSync(ARTIST_METADATA, 'utf8'));
    }
  } catch (_) {}
  return [];
}

