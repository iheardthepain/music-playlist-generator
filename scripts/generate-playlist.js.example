const DEFAULT_SERVER_PORT = Number(config.server?.port) || 3000;
const BASE_URL = normalizeBaseUrl(
  process.env.PLAYLIST_BASE_URL ||
  process.env.PUBLIC_BASE_URL ||
  config.server?.publicBaseUrl ||
  `http://localhost:${DEFAULT_SERVER_PORT}`
);
const DEFAULT_PLAYLIST_COUNT = Number.isFinite(Number(config.playlist?.defaultCount)) && Number(config.playlist?.defaultCount) > 0
  ? Math.floor(Number(config.playlist.defaultCount))
  : 20;
const MAX_PLAYLIST_COUNT = Number.isFinite(Number(config.playlist?.maxCount)) && Number(config.playlist?.maxCount) > 0
  ? Math.floor(Number(config.playlist.maxCount))
  : 50;
const DEFAULT_SUMMARY_COUNT = Number.isFinite(Number(config.playlist?.summaryCount)) && Number(config.playlist?.summaryCount) > 0
  ? Math.floor(Number(config.playlist.summaryCount))
  : DEFAULT_PLAYLIST_COUNT;
const MESSAGE_SUMMARY_COUNT = Number.isFinite(Number(config.playlist?.messageSummaryCount)) && Number(config.playlist?.messageSummaryCount) > 0
  ? Math.floor(Number(config.playlist.messageSummaryCount))
  : Math.min(DEFAULT_SUMMARY_COUNT, 8);

function syncPlaylistRuntimeAfterGeneration() {
  const syncScriptPath = path.resolve(__dirname, 'sync-playlist-runtime.js');
  if (!fs.existsSync(syncScriptPath)) {
    return;
  }

  try {
    const result = spawnSync(process.execPath, [syncScriptPath], {
      cwd: path.resolve(__dirname, '..'),
      windowsHide: true,
      encoding: 'utf8'
    });
    if (result.status !== 0) {
      console.warn('[playlist] runtime sync after generation failed:', (result.stderr || result.stdout || '').trim());
    }
  } catch (error) {
    console.warn('[playlist] runtime sync after generation error:', error.message);
  }
}

function normalizeBaseUrl(value) {
  return (value || '').toString().trim().replace(/\/+$/, '');
}

function buildPlaylistUrl(fileName) {
  const versionToken = Date.now();
  return `${BASE_URL}/playlists/${encodeURIComponent(fileName)}?v=${versionToken}`;
}

function buildCoverUrl(filePath) {
  return `/cover?path=${encodeURIComponent(filePath)}`;
}

function buildPlayUrl(filePath, options = {}) {
  const suffix = options.direct ? '&direct=1' : '';
  return `/play?path=${encodeURIComponent(filePath)}${suffix}`;
}

function buildResolvedPageAudioUrl(audioUrlExpression) {
  return `(() => {
    try {
      return new URL(${audioUrlExpression}, window.location.href).toString();
    } catch (_) {
      return ${audioUrlExpression};
    }
  })()`;
}

function extractPlaylistFileName(playlistUrl) {
  const raw = (playlistUrl || '').toString().trim();
  if (!raw) return '';

  try {
    const parsed = new URL(raw);
    const fileName = parsed.pathname.split('/').pop();
    return fileName ? decodeURIComponent(fileName) : '';
  } catch (_) {
    const match = raw.match(/\/playlists\/([^?#]+)/);
    return match ? decodeURIComponent(match[1]) : '';
  }
}

function ensurePlaylistUrlVersion(playlistUrl) {
  const raw = (playlistUrl || '').toString().trim();
  if (!raw) return raw;

  try {
    const parsed = new URL(raw);
    if (!parsed.searchParams.get('v')) {
      parsed.searchParams.set('v', String(Date.now()));
    }
    return parsed.toString();
  } catch (_) {
    const hasQuery = raw.includes('?');
    const hasVersion = /[?&]v=/.test(raw);
    if (hasVersion) return raw;
    return `${raw}${hasQuery ? '&' : '?'}v=${Date.now()}`;
  }
}

function rewritePlaylistHtmlAssetUrls(fileName) {
  if (!fileName) return;

  const files = [
    path.join(OUTPUT_DIR, fileName),
    path.join(PUBLIC_DIR, fileName)
  ];

  for (const filePath of files) {
    if (!fs.existsSync(filePath)) continue;

    try {
      const content = fs.readFileSync(filePath, 'utf8');
      const updated = content
        .replace(/https?:\/\/[^"'\s]+?\/cover\?path=/g, '/cover?path=')
        .replace(/https?:\/\/[^"'\s]+?\/play\?path=/g, '/play?path=');

      if (updated !== content) {
        fs.writeFileSync(filePath, updated, 'utf8');
      }
    } catch (error) {
      console.warn(`修正缓存歌单页面失败: ${filePath} -> ${error.message}`);
    }
  }
}

function triggerServerAudioCache(fileName) {
  const cacheOptions = config.playlist?.serverAudioCache || {};
  if (cacheOptions.enabled === false) return;
  if (!fileName) return;

  const playlistName = fileName.replace(/-\d+\.html$/, '').replace(/\.html$/, '');
  const cacheDir = path.join(PUBLIC_DIR, playlistName);
  const mappingPath = path.join(cacheDir, '_mapping.json');

  // Skip if this playlist already has a completed server-side cache mapping.
  if (fs.existsSync(mappingPath)) {
    return;
  }

  const cacheScript = path.resolve(__dirname, './cache-playlist-audio.js');
  const useNonBlocking = cacheOptions.nonBlocking !== false;

  try {
    if (useNonBlocking) {
      const child = spawn(process.execPath, [cacheScript, fileName], {
        detached: true,
        stdio: 'ignore',
        windowsHide: true,
        env: process.env
      });
      child.unref();
    } else {
      spawn(process.execPath, [cacheScript, fileName], {
        detached: false,
        stdio: 'ignore',
        windowsHide: true,
        env: process.env
      });
    }
  } catch (error) {
    console.warn(`触发音频缓存失败: ${error.message}`);
  }
}

function normalizePlaylistCount(inputCount) {
  const parsed = Number(inputCount);
  if (!Number.isFinite(parsed) || parsed <= 0) {
    return DEFAULT_PLAYLIST_COUNT;
  }
  return Math.min(Math.floor(parsed), MAX_PLAYLIST_COUNT);
}

