  'default': { bg: '#1a1a2e', accent: '#667eea', text: '#ffffff', vibe: '经典紫蓝' }
};

function getThemeStyle(theme) {
  for (const key of Object.keys(THEME_STYLES)) {
    if (theme.includes(key)) return THEME_STYLES[key];
  }
  return THEME_STYLES['default'];
}

