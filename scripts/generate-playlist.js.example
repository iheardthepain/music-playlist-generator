function cleanMatchText(value) {
  return (value || '')
    .toString()
    .toLowerCase()
    .replace(/^[a-d]?\d{1,3}[.\-_\s]+/i, '')
    .replace(/[_]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function addWeightedTerms(map, terms, weight) {
  for (const term of terms || []) {
    if (!term) continue;
    const key = term.trim();
    if (!key) continue;
    map.set(key, Math.max(map.get(key) || 0, weight));
  }
}

function extractThemeTokens(theme) {
  const tokens = new Set();
  const cleaned = theme.replace(/[：:]/g, ' ').trim();

  cleaned.split(/[\s,，、/|]+/).forEach(token => {
    const value = token.trim();
    if (value) tokens.add(value);
  });

  const chineseParts = cleaned.match(/[\u4e00-\u9fa5]{2,}/g) || [];
  for (const part of chineseParts) {
    const normalized = part.replace(/的/g, '');
    if (normalized.length >= 2) tokens.add(normalized);
  }

  return Array.from(tokens);
}

function buildThemeProfile(theme) {
  const profile = {
    keywords: new Map(),
    artistHints: new Map(),
    exactPhrases: new Map(),
    conceptGroups: [],
    yearPrefixes: [],
    allowSpoken: false,
    requireWestern: false
  };

  addWeightedTerms(profile.exactPhrases, [theme], 12);

  const tokens = extractThemeTokens(theme);
  addWeightedTerms(profile.keywords, tokens.filter(token => token.length >= 2), 3);

  for (const rule of SEMANTIC_THEME_RULES) {
    if (rule.triggers.some(trigger => theme.includes(trigger))) {
      for (const group of rule.concepts || []) {
        profile.conceptGroups.push(group);
        addWeightedTerms(profile.keywords, group, 6);
      }
      addWeightedTerms(profile.artistHints, rule.artists, 7);
      profile.yearPrefixes.push(...(rule.yearPrefixes || []));
      if (rule.allowSpoken) profile.allowSpoken = true;
    }
  }

  if (/\b80s\b|80年代|80后|八十年代|八零/i.test(theme)) {
    profile.conceptGroups.push(['八十年代', '80年代', '80s', '80后']);
    profile.yearPrefixes.push('198');
    addWeightedTerms(profile.artistHints, ['邓丽君', '张学友', '谭咏麟', '梅艳芳', '张国荣', '蔡琴', '李宗盛'], 7);
  }
  if (/\b90s\b|90年代|90后|九十年代|九零/i.test(theme)) {
    profile.conceptGroups.push(['九十年代', '90年代', '90s', '90后']);
    profile.yearPrefixes.push('199');
    addWeightedTerms(profile.artistHints, ['王菲', '陈奕迅', '张惠妹', '林忆莲', 'Beyond', '莫文蔚', '郑秀文'], 7);
  }

  if (/欧美|英文|外文|外国|西洋|western|english|euro|us[-\s]?uk|欧美流行/i.test(theme)) {
    profile.requireWestern = true;
    profile.conceptGroups.push(['欧美', '西洋', '英文', '外文', '外国', 'western', 'english']);
    addWeightedTerms(profile.keywords, ['欧美', '西洋', '英文', '外文', '外国', 'western', 'english', 'pop'], 10);
    addWeightedTerms(profile.artistHints, ['Taylor Swift', 'Adele', 'Coldplay', 'Maroon 5', 'Bruno Mars', 'Ed Sheeran', 'Lady Gaga', 'Katy Perry', 'Billie Eilish', 'Michael Jackson'], 12);
  }

  return profile;
}

function extractYearFromText(text) {
  const value = (text || '').toString();
  if (!value) return null;
  const match = value.match(/(?:19|20)\d{2}/);
  if (!match) return null;
  const year = parseInt(match[0], 10);
  return Number.isFinite(year) ? year : null;
}

function extractTrackYear(track) {
  const eraYear = extractYearFromText(track.era);
  if (eraYear) return eraYear;
  const titleYear = extractYearFromText(track.title);
  if (titleYear) return titleYear;
  const pathYear = extractYearFromText(track.file_path);
  if (pathYear) return pathYear;
  return null;
}

function parseThemeIntent(theme) {
  const value = (theme || '').toString();
  const intent = {
    yearRange: null,
    requireWestern: false,
    requireChinese: false
  };

  if (/\b80s\b|80年代|八十年代|八零|80后/i.test(value)) {
    intent.yearRange = [1980, 1989];
  } else if (/\b90s\b|90年代|九十年代|九零|90后/i.test(value)) {
    intent.yearRange = [1990, 1999];
  } else if (/00年代|零零年代|\b2000s\b/i.test(value)) {
    intent.yearRange = [2000, 2009];
  }

  if (/欧美|英文|外文|外国|西洋|western|english|euro|us[-\s]?uk/i.test(value)) {
    intent.requireWestern = true;
  }

  if (/华语|中文|中国|国语|粤语|国风|中文歌|华语流行/i.test(value)) {
    intent.requireChinese = true;
  }

  return intent;
}

function isLikelyWesternTrack(track) {
  const fields = getTrackFieldTexts(track);
  const westernTokens = ['english', 'western', '欧美', '西洋', '英文', 'eu', 'us', 'uk', 'latin'];
  const nonWesternTokens = ['中文', '华语', '国语', '粤语', '日语', '韩语', '民歌'];
  const combined = `${fields.language} ${fields.genre} ${fields.era} ${fields.filePath}`;

  if (westernTokens.some(token => combined.includes(token))) {
    return true;
  }
  if (nonWesternTokens.some(token => combined.includes(token))) {
    return false;
  }

  const artist = (track.artist || '').toString();
  const title = (track.title || '').toString();
  const hasCjk = /[\u4e00-\u9fa5]/.test(`${artist}${title}`);
  return !hasCjk;
}

function isLikelyChineseTrack(track) {
  const fields = getTrackFieldTexts(track);
  const chineseTokens = ['中文', '华语', '国语', '粤语', 'mandarin', 'cantonese'];
  const westernTokens = ['english', 'western', '欧美', '西洋'];
  const combined = `${fields.language} ${fields.genre} ${fields.era} ${fields.filePath}`;

  if (chineseTokens.some(token => combined.includes(token))) {
    return true;
  }
  if (westernTokens.some(token => combined.includes(token))) {
    return false;
  }

  const artist = (track.artist || '').toString();
  const title = (track.title || '').toString();
  return /[\u4e00-\u9fa5]/.test(`${artist}${title}`);
}

function getTrackFieldTexts(track) {
  return {
    title: cleanMatchText(track.title),
    artist: cleanMatchText(track.artist),
    genre: cleanMatchText(track.genre),
    mood: cleanMatchText(track.mood),
    era: cleanMatchText(track.era),
    language: cleanMatchText(track.language),
    notes: cleanMatchText(track.notes),
    filePath: cleanMatchText(track.file_path)
  };
}

function scoreTrackAgainstTheme(track, profile) {
  const fields = getTrackFieldTexts(track);
  let score = 0;
  let matchedConceptGroups = 0;
  const combinedText = `${fields.title} ${fields.artist} ${fields.genre} ${fields.mood} ${fields.era} ${fields.language} ${fields.notes} ${fields.filePath}`;

  if (!profile.allowSpoken && fields.genre === 'spoken-comedy') {
    score -= 300;
  }
  if (profile.allowSpoken && fields.genre === 'spoken-comedy') {
    score += 120;
  }

  if (profile.requireWestern) {
    if (isLikelyWesternTrack(track)) {
      score += 180;
    } else {
      score -= 220;
    }
  }

  for (const [phrase, weight] of profile.exactPhrases.entries()) {
    const term = cleanMatchText(phrase);
    if (!term) continue;
    if (fields.title.includes(term)) score += weight * 30;
    if (fields.artist.includes(term)) score += weight * 28;
    if (fields.genre.includes(term)) score += weight * 20;
    if (fields.filePath.includes(term)) score += weight * 16;
    if (fields.notes.includes(term)) score += weight * 12;
  }

  for (const group of profile.conceptGroups) {
    if (group.some(term => combinedText.includes(cleanMatchText(term)))) {
      matchedConceptGroups += 1;
      score += 30;
    }
  }

  for (const [keyword, weight] of profile.keywords.entries()) {
    const term = cleanMatchText(keyword);
    if (!term || term.length < 2) continue;
    if (fields.title.includes(term)) score += weight * 10;
    if (fields.artist.includes(term)) score += weight * 9;
    if (fields.genre.includes(term)) score += weight * 8;
    if (fields.mood.includes(term)) score += weight * 8;
    if (fields.era.includes(term)) score += weight * 8;
    if (fields.language.includes(term)) score += weight * 6;
    if (fields.filePath.includes(term)) score += weight * 5;
    if (fields.notes.includes(term)) score += weight * 4;
  }

  for (const prefix of profile.yearPrefixes) {
    if (fields.title.includes(prefix) || fields.filePath.includes(prefix)) {
      score += 50;
    }
  }

  for (const [artistHint, weight] of profile.artistHints.entries()) {
    const term = cleanMatchText(artistHint);
    if (!term) continue;
    if (fields.artist.includes(term)) score += weight * 16;
    if (fields.filePath.includes(term)) score += weight * 6;
  }

  if (matchedConceptGroups >= 2) {
    score += matchedConceptGroups * 20;
  }

  if (profile.conceptGroups.length >= 2 && matchedConceptGroups === 0) {
    score -= 40;
  }

  return score;
}

function buildTrackKey(track) {
  const artist = cleanMatchText(track.artist);
  const title = cleanMatchText(track.title);
  return `${artist}::${title}`;
}

function selectTracksForTheme(rows, theme, count) {
  const profile = buildThemeProfile(theme);
  const intent = parseThemeIntent(theme);
  const ranked = rows
    .map(track => {
      const score = scoreTrackAgainstTheme(track, profile);
      // 保留关键词分，供后续向量混合排序使用
      track._keywordScore = score;
      return { track, score };
    })
    .sort((a, b) => b.score - a.score || Math.random() - 0.5);

  const positiveRanked = ranked.filter(item => item.score > 0);
  let source = positiveRanked.length > 0 ? positiveRanked : ranked;

  if (profile.requireWestern) {
    const westernOnly = source.filter(item => isLikelyWesternTrack(item.track));
    if (westernOnly.length > 0) {
      source = westernOnly;
    }
  }

  if (intent.requireChinese && !intent.requireWestern) {
    const chineseOnly = source.filter(item => isLikelyChineseTrack(item.track));
    if (chineseOnly.length > 0) {
      source = chineseOnly;
    }
  }

  if (intent.yearRange) {
    const [startYear, endYear] = intent.yearRange;
    const yearMatched = source.filter(item => {
      const year = extractTrackYear(item.track);
      return year !== null && year >= startYear && year <= endYear;
    });

    const minimumAcceptable = Math.max(5, Math.floor(count * 0.4));
    if (yearMatched.length >= minimumAcceptable) {
      source = yearMatched;
    }
  }

  const selected = [];
  const seen = new Set();

  for (const item of source) {
    if (!profile.allowSpoken && cleanMatchText(item.track.genre) === 'spoken-comedy') {
      continue;
    }

    const key = buildTrackKey(item.track);
    if (seen.has(key)) continue;
    seen.add(key);
    selected.push(item.track);
    if (selected.length >= count) break;
  }

  if (selected.length < count) {
    for (const item of ranked) {
      const key = buildTrackKey(item.track);
      if (seen.has(key)) continue;
      seen.add(key);
      selected.push(item.track);
      if (selected.length >= count) break;
    }
  }

  return selected;
}

/**
 * 纯向量搜索：直接用语义相似度选歌
 * @param {string}   theme    主题文本
 * @param {number}   count    需要的歌曲数
 * @param {object[]} allRows  数据库中所有 tracks（已加载）
 * @returns {Promise<object[]>} 选出的歌曲列表
 */
async function selectTracksVectorOnly(theme, count, allRows) {
  if (!vectorSearchModule) {
    throw new Error('vector-search 模块未加载');
  }

  // topK 取请求数量的 4 倍，再从中去重选 count 首
  const topK = Math.min(count * 4, 800);
  const { trackIds, similarities } = await vectorSearchModule.vectorSearch(theme, {
    topK,
    minSimilarity: 0.2
  });

  if (trackIds.length === 0) return [];

  // 建立 id→track 索引
  const trackMap = new Map(allRows.map(r => [r.id, r]));

  const profile = buildThemeProfile(theme);
  const selected = [];
  const seen = new Set();

  for (const tid of trackIds) {
    const track = trackMap.get(tid);
    if (!track) continue;
    if (!profile.allowSpoken && cleanMatchText(track.genre) === 'spoken-comedy') continue;

    const key = buildTrackKey(track);
    if (seen.has(key)) continue;
    seen.add(key);

    track._vectorScore = similarities.get(tid) || 0;
    selected.push(track);
    if (selected.length >= count) break;
  }

  return selected;
}

/**
 * 混合搜索：关键词匹配 + 向量重排
 * @param {object[]} allRows  全部 tracks
 * @param {string}   theme    主题
 * @param {number}   count    需要的歌曲数
 * @returns {Promise<object[]>}
 */
async function selectTracksHybrid(allRows, theme, count) {
  if (!vectorSearchModule) {
    return selectTracksForTheme(allRows, theme, count);
  }

  // 先用关键词匹配取较多候选（count*3，最多 200）
  const candidateCount = Math.min(count * 3, 200);
  const candidates = selectTracksForTheme(allRows, theme, candidateCount);

  // 用向量对候选重排
  try {
    const reranked = await vectorSearchModule.hybridRerank(candidates, theme, {
      vectorWeight: 0.45,
      keywordWeight: 0.55
    });
    return reranked.slice(0, count);
  } catch (err) {
    console.warn(`[playlist] 向量重排失败，使用关键词排序: ${err.message}`);
    return candidates.slice(0, count);
  }
}

/**
 * 生成歌单
 * @param {string} theme   主题
 * @param {number} count   歌曲数量
 * @param {object} options 选项
 * @param {string} options.searchMode  'keyword' | 'vector'（纯向量）| 'hybrid'（混合）| 'auto'（读配置）
 */
async function generatePlaylist(theme, count = DEFAULT_PLAYLIST_COUNT, options = {}) {
  const safeCount = normalizePlaylistCount(count);
  // 读取 config.json 中的 useVectorSearch 配置，未传 searchMode 时自动选择
  let searchMode = options.searchMode || 'auto';
  if (searchMode === 'auto') {
    searchMode = config.playlist?.useVectorSearch ? 'vector' : 'keyword';
  }
  const serverReady = await ensureWebServerReady();

  // 检查缓存（仅 keyword 模式使用缓存，vector/hybrid 每次实时计算）
  if (searchMode === 'keyword') {
    const cached = getCachedPlaylist(theme);
    if (cached) {
      const cachedTracks = Array.isArray(cached.tracks) ? cached.tracks : [];
      const playlistUrl = ensurePlaylistUrlVersion(cached.playlistUrl || '');
      const cachedFileName = extractPlaylistFileName(playlistUrl);
      rewritePlaylistHtmlAssetUrls(cachedFileName);
      triggerServerAudioCache(cachedFileName);
      return {
        success: true,
        message: buildPlaylistMessage(theme, cachedTracks, playlistUrl, true),
        playlistUrl,
        playlistIntro: buildPlaylistIntro(theme, cachedTracks),
        playlistSummaryTable: buildPlaylistSummaryTable(cachedTracks),
        cached: true,
        searchMode: 'keyword'
      };
    }
  }

  return new Promise((resolve, reject) => {
    const db = new sqlite3.Database(DB_PATH);

    // 搜索匹配主题的歌曲
    let sql, params;
    if (theme.toLowerCase() === 'random') {
      sql = `SELECT * FROM tracks ORDER BY RANDOM() LIMIT ?`;
      params = [safeCount];
    } else {
      sql = `SELECT * FROM tracks`;
      params = [];
    }

    db.all(sql, params, async (err, rows) => {
      if (err) {
        db.close();
        return resolve({ success: false, message: `❌ 数据库错误: ${err.message}`, playlistUrl: '' });
      }

      if (!rows || rows.length === 0) {
        db.close();
        return resolve({
          success: false,
          message: `😅 没有找到「${theme}」相关的歌曲\n💡 试试：流行、古典、周杰伦、random`,
          playlistUrl: ''
        });
      }

      if (theme.toLowerCase() !== 'random') {
        // 保留全量数据引用，供降级使用
        const allRows = rows;
        // 根据 searchMode 选择不同的选歌策略
        try {
          if (searchMode === 'vector' && vectorSearchModule) {
            // 纯向量搜索
            const vectorResults = await selectTracksVectorOnly(theme, safeCount, allRows);
            if (vectorResults.length === 0) {
              // 向量库为空时降级到关键词匹配（使用原始全量数据）
              console.warn('[playlist] 向量库无结果，降级到关键词匹配');
              rows = selectTracksForTheme(allRows, theme, safeCount);
            } else {
              rows = vectorResults;
            }
          } else if (searchMode === 'hybrid' && vectorSearchModule) {
            // 混合搜索：关键词初筛 + 向量重排
            rows = await selectTracksHybrid(allRows, theme, safeCount);
          } else {
            // 默认：纯关键词匹配（原有逻辑，向后兼容）
            rows = selectTracksForTheme(allRows, theme, safeCount);
          }
        } catch (vecErr) {
          console.warn(`[playlist] 向量搜索出错，降级关键词匹配: ${vecErr.message}`);
          rows = selectTracksForTheme(allRows, theme, safeCount);
        }
      }

      // 加载艺术家元数据，兼容数组和对象两种存储形态
      const artistData = loadArtistMetadata();
      const artistMap = {};
      if (Array.isArray(artistData)) {
        artistData.forEach(item => {
          if (item && item.artist) {
            artistMap[item.artist] = item.metadata || {};
          }
        });
      } else if (artistData && typeof artistData === 'object') {
        Object.keys(artistData).forEach((artist) => {
          artistMap[artist] = artistData[artist] || {};
        });
      }

      // 加载歌词
      const trackIds = rows.map(r => r.id).filter(Boolean);
      const lyricsMap = {};
      
      const loadLyricsAndGenerate = () => {
        // 生成HTML
        const fileName = `${theme.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5]/gi, '-')}-${Date.now()}.html`;
        const html = generateVinylHtml(theme, rows, artistMap, lyricsMap);
        
        // 保存文件
        fs.mkdirSync(OUTPUT_DIR, { recursive: true });
        fs.mkdirSync(PUBLIC_DIR, { recursive: true });
        const outputPath = path.join(OUTPUT_DIR, fileName);
        const publicPath = path.join(PUBLIC_DIR, fileName);
        fs.writeFileSync(outputPath, html, 'utf8');
        fs.writeFileSync(publicPath, html, 'utf8');
        syncPlaylistRuntimeAfterGeneration();
        rewritePlaylistHtmlAssetUrls(fileName);
        triggerServerAudioCache(fileName);

        // 创建桌面快捷方式
        createDesktopShortcut(outputPath);

        const playlistUrl = buildPlaylistUrl(fileName);
        
        // 缓存（仅 keyword 模式缓存，vector/hybrid 不缓存以保证每次语义新鲜）
        if (searchMode === 'keyword') {
          cachePlaylist(theme, { tracks: rows, playlistUrl, theme });
        }

        db.close();
        const serverWarning = serverReady ? '' : '\n⚠️ 音乐服务未能及时启动，链接可能暂时不可用，请稍后重试。';
        resolve({
          success: true,
          message: buildPlaylistMessage(theme, rows, playlistUrl, false) + serverWarning,
          playlistUrl,
          playlistIntro: buildPlaylistIntro(theme, rows),
          playlistSummaryTable: buildPlaylistSummaryTable(rows),
          cached: false,
          searchMode,
          serverReady
        });
      };

      if (trackIds.length > 0) {
        db.all(`SELECT track_id, lyrics FROM lyrics WHERE track_id IN (${trackIds.join(',')})`, [], (err, lyricsRows) => {
          if (!err && lyricsRows) {
            lyricsRows.forEach(row => { lyricsMap[row.track_id] = row.lyrics; });
          }
          loadLyricsAndGenerate();
        });
      } else {
        loadLyricsAndGenerate();
      }
    });
  });
}

// 创建桌面快捷方式
function createDesktopShortcut(targetPath) {
  try {
    const desktopPath = path.join(process.env.USERPROFILE || require('os').homedir(), 'Desktop', '我的最新歌单.url');
    const urlContent = `[InternetShortcut]\nURL=file:///${targetPath.replace(/\\/g, '/')}\n`;
    fs.writeFileSync(desktopPath, urlContent, 'utf8');
  } catch (e) {
    console.warn('创建快捷方式失败:', e.message);
  }
}

// 生成传统黑胶唱片风格HTML
function generateVinylHtml(theme, tracks, artistMetadata, lyricsMap) {
  const style = getThemeStyle(theme);
  const musicRoot = 'YOUR_MUSIC_PROJECT_DIR';
  
  // 找一个有封面的歌曲作为主封面
  let mainCover = '';
  for (const track of tracks) {
    const cover = findCoverArt(track.file_path);
    if (cover) {
      mainCover = buildCoverUrl(cover);
      break;
    }
  }

  // 格式化文件大小显示
  const formatFileSize = (bytes) => {
    if (!bytes || bytes === 0) return '';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  };

  const trackListHtml = tracks.map((track, i) => {
    const cover = findCoverArt(track.file_path);
    let coverUrl = '';
    if (cover) {
      coverUrl = buildCoverUrl(cover);
    }
    
    const audioUrl = buildPlayUrl(track.file_path);
    const sourceAudioUrl = buildPlayUrl(track.file_path, { direct: true });

    const artist = track.artist || '未知艺术家';
    const title = track.title || '未知标题';
    const aInfo = artistMetadata[artist];
    const bio = aInfo && aInfo.description ? aInfo.description : '';
    const lyrics = lyricsMap[track.id] || '';
    const fileSize = formatFileSize(track.file_size);

    const estimatedBytes = Number.isFinite(Number(track.file_size)) ? Math.max(0, Number(track.file_size)) : 0;

    return `
    <div class="track" data-audio="${audioUrl}" data-audio-fallback="${sourceAudioUrl}" data-audio-source="${sourceAudioUrl}" data-audio-size="${estimatedBytes}" data-cover="${coverUrl}">
      <div class="track-num">${String(i + 1).padStart(2, '0')}</div>
      <div class="track-info">
        <div class="track-title">${title}</div>
        <div class="track-artist">${artist} ${fileSize ? `<span class="file-size">• ${fileSize}</span>` : ''}</div>
      </div>
      <div class="track-duration">♪</div>
      ${bio ? `<div class="track-bio hidden">${bio}</div>` : ''}
      ${lyrics ? `<div class="track-lyrics hidden">${lyrics}</div>` : ''}
    </div>`;
  }).join('\n');

  // 仅预加载主封面，避免一次性预加载大量图片干扰音频链路。
  const preloadLinks = mainCover
    ? `<link rel="preload" as="image" href="${mainCover}">`
    : '';

  return `<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>${theme} - 私人唱片</title>
${preloadLinks}
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: ${style.bg};
  color: ${style.text};
  min-height: 100vh;
}

/* 唱片封面区域 */
.album-cover {
  position: relative;
  width: 100%;
  max-width: 500px;
  margin: 0 auto;
  padding: 40px 20px;
}

.vinyl-container {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
}

.vinyl-record {
  position: absolute;
  width: 90%;
  height: 90%;
  right: 0;
  top: 5%;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, 
    #1a1a1a 0%, #1a1a1a 15%, 
    #333 15.5%, #222 16%, 
    #333 25%, #222 25.5%,
    #333 35%, #222 35.5%,
    #333 45%, #1a1a1a 46%,
    #1a1a1a 100%);
  box-shadow: 0 0 30px rgba(0,0,0,0.5);
  animation: spin 8s linear infinite paused;
}

.vinyl-record.playing { animation-play-state: running; }

.vinyl-label {
  position: absolute;
  width: 35%;
  height: 35%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: ${style.accent};
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 0.8em;
  text-align: center;
  color: ${style.bg};
  padding: 10px;
  overflow: hidden;
}

.vinyl-label .label-title {
  font-size: 0.7em;
  font-weight: bold;
  margin-bottom: 2px;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vinyl-label .label-artist {
  font-size: 0.6em;
  opacity: 0.8;
  max-width: 90%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cover-sleeve {
  position: absolute;
  width: 85%;
  height: 85%;
  left: 0;
  top: 7.5%;
  background: ${mainCover ? `url("${mainCover}") center/cover` : style.accent};
  border-radius: 8px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  z-index: 2;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30px 20px;
  background: linear-gradient(transparent, rgba(0,0,0,0.9));
  border-radius: 0 0 8px 8px;
}

.album-title {
  font-size: 2em;
  font-weight: 700;
  margin-bottom: 8px;
  color: #fff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}

.album-meta {
  font-size: 0.95em;
  opacity: 0.9;
  color: ${style.accent};
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 播放器控制 */
.player-bar {
  background: rgba(0,0,0,0.8);
  backdrop-filter: blur(20px);
  padding: 15px 20px;
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 15px;
}

.now-playing {
  flex: 1;
  min-width: 0;
}

.now-playing-title {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.now-playing-artist {
  font-size: 0.85em;
  opacity: 0.7;
}

.play-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: ${style.accent};
  border: none;
  color: ${style.bg};
  font-size: 1.5em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.play-btn:hover { transform: scale(1.1); }

.progress-bar {
  flex: 2;
  height: 6px;
  background: rgba(255,255,255,0.2);
  border-radius: 3px;
  position: relative;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: ${style.accent};
  border-radius: 3px;
  width: 0%;
  transition: width 0.1s;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
}

.offline-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.offline-download-btn {
  border: 1px solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.08);
  color: #fff;
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 0.78em;
  cursor: pointer;
}

.offline-download-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

.offline-status-text {
  min-width: 150px;
  font-size: 0.78em;
  opacity: 0.9;
  text-align: right;
}

/* 曲目列表 */
.track-list {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
}

.section-title {
  font-size: 1.2em;
  color: ${style.accent};
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 2px solid ${style.accent};
}

.track {
  display: flex;
  align-items: center;
  padding: 15px;
  border-radius: 10px;
  cursor: pointer;
  transition: background 0.2s;
  gap: 15px;
}

.track:hover, .track.active {
  background: rgba(255,255,255,0.1);
}

.track.active {
  border-left: 3px solid ${style.accent};
}

.track-num {
  font-size: 0.9em;
  opacity: 0.5;
  width: 30px;
}

.track-info { flex: 1; min-width: 0; }

.track-title {
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-artist {
  font-size: 0.85em;
  opacity: 0.7;
  margin-top: 2px;
}

.file-size {
  font-size: 0.8em;
  opacity: 0.5;
}

.track-duration {
  opacity: 0.5;
}

.hidden { display: none; }

/* 歌词弹窗 */
.lyrics-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  z-index: 200;
  overflow-y: auto;
  padding: 60px 20px;
}

.lyrics-modal.show { display: block; }

.lyrics-content {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  line-height: 2;
  font-size: 1.1em;
  white-space: pre-wrap;
}

.lyrics-close {
  position: fixed;
  top: 20px;
  right: 20px;
  background: none;
  border: none;
  color: #fff;
  font-size: 2em;
  cursor: pointer;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 40px;
  opacity: 0.5;
  font-size: 0.9em;
}

@media (max-width: 600px) {
  .album-cover { padding: 20px 10px; }
  .album-title { font-size: 1.5em; }
  .player-bar { flex-wrap: wrap; }
  .progress-bar { order: 3; flex-basis: 100%; margin-top: 10px; }
}
</style>
</head>
<body>

<div class="album-cover">
  <div class="vinyl-container">
    <div class="vinyl-record" id="vinyl">
      <div class="vinyl-label">${theme}</div>
    </div>
    <div class="cover-sleeve">
      <div class="cover-overlay">
        <div class="album-title">${theme}</div>
        <div class="album-meta">${tracks.length} 首歌曲 · ${style.vibe}</div>
      </div>
    </div>
  </div>
</div>

<div class="player-bar">
  <button class="play-btn" id="playBtn">▶</button>
  <div class="now-playing">
    <div class="now-playing-title" id="nowTitle">选择一首歌曲</div>
    <div class="now-playing-artist" id="nowArtist">-</div>
  </div>
  <div class="progress-bar" id="progressBar">
    <div class="progress-fill" id="progressFill"></div>
  </div>
  <div class="offline-actions">
    <button class="offline-download-btn" id="downloadOfflineBtn">下载离线音频</button>
    <div class="offline-status-text" id="offlineStatusText">检查SSD转码状态中...</div>
  </div>
</div>

<div class="track-list">
  <div class="section-title">🎵 曲目列表</div>
  ${trackListHtml}
</div>

<div class="lyrics-modal" id="lyricsModal">
  <button class="lyrics-close" onclick="closeLyrics()">×</button>
  <div class="lyrics-content" id="lyricsContent"></div>
</div>

<div class="footer">
  🎵 私人音乐库 · ${new Date().toLocaleDateString('zh-CN')}
</div>

<audio id="audioPlayer"></audio>

<script>
const audio = document.getElementById('audioPlayer');
const playBtn = document.getElementById('playBtn');
const vinyl = document.getElementById('vinyl');
const nowTitle = document.getElementById('nowTitle');
const nowArtist = document.getElementById('nowArtist');
const progressBar = document.getElementById('progressBar');
const progressFill = document.getElementById('progressFill');
let downloadOfflineBtn = document.getElementById('downloadOfflineBtn');
let offlineStatusText = document.getElementById('offlineStatusText');
const tracks = document.querySelectorAll('.track');
let currentTrack = null;
let currentBlobUrl = '';

tracks.forEach((track, index) => {
  track.addEventListener('click', () => {
    playTrack(track, index);
  });
  
  track.addEventListener('dblclick', () => {
    const lyrics = track.querySelector('.track-lyrics');
    if (lyrics) showLyrics(lyrics.textContent);
  });
});

function clearCurrentBlobUrl() {
  if (!currentBlobUrl) return;
  try {
    URL.revokeObjectURL(currentBlobUrl);
  } catch (_) {}
  currentBlobUrl = '';
}

async function playTrack(track, index) {
  let forceSourcePlayback = false;

  const playbackUrls = getImmediateTrackPlaybackUrls(track);
  const audioUrl = playbackUrls.preferredUrl;
  const fallbackUrl = playbackUrls.fallbackUrl || '';
  const directFallbackUrl = playbackUrls.directFallbackUrl || fallbackUrl || '';
  const coverUrl = track.dataset.cover;
  const title = track.querySelector('.track-title').textContent;
  const artist = track.querySelector('.track-artist').textContent;
  
  tracks.forEach(t => t.classList.remove('active'));
  track.classList.add('active');
  
  nowTitle.textContent = title;
  nowArtist.textContent = artist;
  
  const coverSleeve = document.querySelector('.cover-sleeve');
  const vinylLabel = document.querySelector('.vinyl-label');
  const resolvedFallbackUrl = fallbackUrl;
  const resolvedDirectFallbackUrl = directFallbackUrl;
  
  if (coverUrl && coverUrl.trim() !== '') {
    // 有封面，显示封面图片
    coverSleeve.style.display = 'block';
    coverSleeve.style.backgroundImage = 'url("' + coverUrl + '")';
    const albumTitleEl = document.querySelector('.album-title');
    vinylLabel.innerHTML = (albumTitleEl && albumTitleEl.textContent) || '${theme}';
  } else {
    // 没有封面，隐藏封面，显示黑胶唱片和歌曲信息
    coverSleeve.style.display = 'none';
    vinylLabel.innerHTML = '<div class="label-title">' + title + '</div><div class="label-artist">' + artist + '</div>';
  }

  if (!isServerCacheAudioUrl(track.dataset.audio || '')) {
    refreshServerCacheMapping(false).catch(() => {});
  }

  const primaryUrl = forceSourcePlayback
    ? (resolvedFallbackUrl || resolvedDirectFallbackUrl || audioUrl)
    : audioUrl;
  const trySwitchToFallback = () => {
    if (!resolvedFallbackUrl || audio.src === resolvedFallbackUrl) {
      return false;
    }
    forceSourcePlayback = true;
    clearCurrentBlobUrl();
    audio.src = resolvedFallbackUrl;
    audio.play().catch(() => {
      if (!resolvedDirectFallbackUrl || audio.src === resolvedDirectFallbackUrl) {
        return;
      }
      audio.src = resolvedDirectFallbackUrl;
      audio.play().catch(() => {});
    });
    return true;
  };
  const switchToDirectFallback = () => {
    if (!resolvedDirectFallbackUrl || audio.src === resolvedDirectFallbackUrl) {
      return;
    }
    forceSourcePlayback = true;
    clearCurrentBlobUrl();
    audio.src = resolvedDirectFallbackUrl;
    audio.play().catch(() => {});
  };

  let startupTimer = null;
  let startupHardTimer = null;
  const clearStartupTimer = () => {
    if (startupTimer) {
      clearTimeout(startupTimer);
      startupTimer = null;
    }
    if (startupHardTimer) {
      clearTimeout(startupHardTimer);
      startupHardTimer = null;
    }
    audio.removeEventListener('timeupdate', clearStartupGuardOnProgress);
  };

  const clearStartupGuardOnProgress = () => {
    if ((audio.currentTime || 0) > 0.2) {
      clearStartupTimer();
    }
  };

  clearCurrentBlobUrl();
  // 隐患2修复：先设置 onerror 再设置 src，避免同步错误被吞
  audio.onerror = (e) => {
    console.warn('[player] audio error, switching to fallback', e);
    clearStartupTimer();
    if (!trySwitchToFallback()) {
      switchToDirectFallback();
    }
  };
  audio.addEventListener('playing', clearStartupTimer, { once: true });
  audio.addEventListener('timeupdate', clearStartupGuardOnProgress);
  // 监听浏览器原生 stalled 事件（比定时器更准确）
  audio.addEventListener('stalled', () => {
    if ((audio.currentTime || 0) < 0.05 && !audio.ended) {
      console.warn('[player] stalled event, switching to fallback');
      clearStartupTimer();
      if (!trySwitchToFallback()) {
        switchToDirectFallback();
      }
    }
  }, { once: true });
  audio.src = primaryUrl;
  audio.play().catch((err) => {
    console.warn('[player] play() rejected:', err.message || err);
    clearStartupTimer();
    audio.removeEventListener('timeupdate', clearStartupGuardOnProgress);
    if (!trySwitchToFallback()) {
      switchToDirectFallback();
    }
  });

  // 超时优化：3s→6s 软超时，避免慢网络下误判 SSD 缓存
  startupTimer = setTimeout(() => {
    const stalled = (audio.currentTime || 0) < 0.05 && !audio.ended;
    if (stalled) {
      console.warn('[player] 6s soft timeout, switching to fallback');
      if (!trySwitchToFallback()) {
        switchToDirectFallback();
      }
    }
  }, 6000);

  // 7s→12s 硬超时
  startupHardTimer = setTimeout(() => {
    const stalled = (audio.currentTime || 0) < 0.05 && !audio.ended;
    if (stalled) {
      console.warn('[player] 12s hard timeout, switching to direct fallback');
      switchToDirectFallback();
    }
  }, 12000);
  currentTrack = index;
}

playBtn.addEventListener('click', () => {
  if (audio.paused) {
    if (!audio.src && tracks.length > 0) {
      playTrack(tracks[0], 0);
    } else {
      audio.play();
    }
  } else {
    audio.pause();
  }
});

audio.addEventListener('play', () => {
  playBtn.textContent = '⏸';
  vinyl.classList.add('playing');
  requestAnimationFrame(updateProgress);
});

audio.addEventListener('pause', () => {
  playBtn.textContent = '▶';
  vinyl.classList.remove('playing');
});

// 更新进度条，确保和播放同步
function updateProgress() {
  if (audio.duration) {
    const percent = (audio.currentTime / audio.duration * 100);
    progressFill.style.width = percent + '%';
  }
  if (!audio.paused) {
    requestAnimationFrame(updateProgress);
  }
}

audio.addEventListener('timeupdate', updateProgress);

audio.addEventListener('ended', () => {
  if (currentTrack !== null && currentTrack < tracks.length - 1) {
    playTrack(tracks[currentTrack + 1], currentTrack + 1);
  }
});

function showLyrics(text) {
  document.getElementById('lyricsContent').textContent = text;
  document.getElementById('lyricsModal').classList.add('show');
}

function closeLyrics() {
  document.getElementById('lyricsModal').classList.remove('show');
}

// SSD预转码在线播放 + 离线音频下载（非zip）
const offlineDownloadState = {
  ready: false,
  files: [],
  playlistFileName: ''
};

function ensureOfflineControls() {
  if (downloadOfflineBtn && offlineStatusText) return;

  const playerBar = document.querySelector('.player-bar');
  if (!playerBar) return;

  let offlineActions = playerBar.querySelector('.offline-actions');
  if (!offlineActions) {
    offlineActions = document.createElement('div');
    offlineActions.className = 'offline-actions';
    offlineActions.style.display = 'flex';
    offlineActions.style.flexDirection = 'column';
    offlineActions.style.gap = '6px';
    offlineActions.style.minWidth = '180px';
    playerBar.appendChild(offlineActions);
  }

  if (!downloadOfflineBtn) {
    downloadOfflineBtn = document.createElement('button');
    downloadOfflineBtn.className = 'offline-download-btn';
    downloadOfflineBtn.id = 'downloadOfflineBtn';
    downloadOfflineBtn.type = 'button';
    downloadOfflineBtn.textContent = '下载离线音频';
    offlineActions.appendChild(downloadOfflineBtn);
  }

  if (!offlineStatusText) {
    offlineStatusText = document.createElement('div');
    offlineStatusText.className = 'offline-status-text';
    offlineStatusText.id = 'offlineStatusText';
    offlineStatusText.textContent = '检查SSD转码状态中...';
    offlineActions.appendChild(offlineStatusText);
  }
}

ensureOfflineControls();

function placeOfflineControlsUnderPlayButton() {
  const playerBar = document.querySelector('.player-bar');
  const playButton = document.getElementById('playBtn');
  const offlineActions = document.querySelector('.offline-actions');
  if (!playerBar || !playButton || !offlineActions) return;

  let playControlRail = document.getElementById('playControlRail');
  if (!playControlRail) {
    playControlRail = document.createElement('div');
    playControlRail.id = 'playControlRail';
    const nowPlaying = playerBar.querySelector('.now-playing');
    if (nowPlaying) {
      playerBar.insertBefore(playControlRail, nowPlaying);
    } else {
      playerBar.insertBefore(playControlRail, playerBar.firstChild);
    }
  }

  playControlRail.style.display = 'flex';
  playControlRail.style.flexDirection = 'column';
  playControlRail.style.alignItems = 'center';
  playControlRail.style.justifyContent = 'center';
  playControlRail.style.gap = '8px';
  playControlRail.style.minWidth = '86px';
  playControlRail.style.flexShrink = '0';

  if (playButton.parentElement !== playControlRail) {
    playControlRail.appendChild(playButton);
  }
  if (offlineActions.parentElement !== playControlRail) {
    playControlRail.appendChild(offlineActions);
  }

  offlineActions.style.display = 'flex';
  offlineActions.style.flexDirection = 'column';
  offlineActions.style.alignItems = 'center';
  offlineActions.style.gap = '6px';
  offlineActions.style.minWidth = '0';
  offlineActions.style.width = '100%';

  if (offlineStatusText) {
    offlineStatusText.style.textAlign = 'center';
    offlineStatusText.style.minWidth = '0';
    offlineStatusText.style.maxWidth = '170px';
  }

  if (downloadOfflineBtn) {
    downloadOfflineBtn.style.whiteSpace = 'nowrap';
  }
}

placeOfflineControlsUnderPlayButton();

function setPlaybackCachePriority(_) {
  // 浏览器缓存功能已停用，仅保留函数占位避免历史调用报错。
}

function getCurrentPlaylistFileName() {
  try {
    const url = new URL(window.location.href);
    const name = decodeURIComponent((url.pathname || '').split('/').pop() || '');
    return name;
  } catch (_) {
    return '';
  }
}

function setOfflineStatus(text, isError) {
  if (!offlineStatusText) return;
  offlineStatusText.textContent = text || '';
  offlineStatusText.style.color = isError ? '#ff9b9b' : '';
}

function setDownloadButtonState(disabled) {
  if (!downloadOfflineBtn) return;
  downloadOfflineBtn.disabled = Boolean(disabled);
}

function waitMs(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function toAbsoluteAudioUrl(url) {
  if (!url) return '';
  try {
    return new URL(url, window.location.href).toString();
  } catch (_) {
    return url;
  }
}

function ensureDirectPlayUrl(url) {
  const value = (url || '').toString();
  if (!/\/play\?path=/i.test(value) || /(?:\?|&)direct=1(?:&|$)/i.test(value)) {
    return value;
  }
  return value + (value.includes('?') ? '&' : '?') + 'direct=1';
}

function getTrackSourceUrl(track) {
  return track.dataset.audioSource || track.dataset.audioFallback || track.dataset.audio || '';
}

function isServerCacheAudioUrl(url) {
  const value = (url || '').toString();
  return /(?:^|\/)playlists\/.+\.m4a(?:$|[?#])/i.test(value);
}

function getPlaylistNameFromLocation() {
  try {
    const current = new URL(window.location.href);
    const fileName = decodeURIComponent((current.pathname || '').split('/').pop() || '');
    return fileName.replace(/-\d+\.html$/, '').replace(/\.html$/, '');
  } catch (_) {
    return '';
  }
}

function buildServerCacheMappingUrl() {
  const playlistName = getPlaylistNameFromLocation();
  if (!playlistName) return '';

  try {
    return new URL('./' + encodeURIComponent(playlistName) + '/_mapping.json', window.location.href).toString();
  } catch (_) {
    return '';
  }
}

function buildServerCacheAudioUrl(outputFileName) {
  const playlistName = getPlaylistNameFromLocation();
  if (!playlistName || !outputFileName) return '';

  try {
    return new URL('./' + encodeURIComponent(playlistName) + '/' + encodeURIComponent(outputFileName), window.location.href).toString();
  } catch (_) {
    return '';
  }
}

let serverCacheMappingLoaded = false;
let serverCacheMappingAvailable = false;
let serverCacheRefreshPromise = null;
let lastServerCacheRefreshAt = 0;
const SERVER_CACHE_REFRESH_INTERVAL_MS = 15000;

function applyServerCacheMapping(mappingEntries) {
  const entries = Array.isArray(mappingEntries) ? mappingEntries : [];

  const normalizeSourcePath = (value) => String(value || '').replace(/\\/g, '/').toLowerCase();
  const extractSourcePathFromPlayUrl = (value) => {
    try {
      const parsed = new URL(String(value || ''), window.location.href);
      const sourcePath = parsed.searchParams.get('path') || '';
      return decodeURIComponent(sourcePath);
    } catch (_) {
      return '';
    }
  };

  const entryBySourcePath = new Map();
  entries.forEach((entry) => {
    const key = normalizeSourcePath(entry && entry.inputPath);
    if (!key) return;
    if (!entryBySourcePath.has(key)) {
      entryBySourcePath.set(key, entry);
    }
  });

  tracks.forEach((track, index) => {
    const sourceUrl = getTrackSourceUrl(track);
    if (sourceUrl && !track.dataset.audioSource) {
      track.dataset.audioSource = sourceUrl;
    }

    const sourcePath = extractSourcePathFromPlayUrl(sourceUrl);
    const entry = entryBySourcePath.get(normalizeSourcePath(sourcePath)) || entries[index];
    const cachedUrl = entry && entry.outputFileName
      ? buildServerCacheAudioUrl(entry.outputFileName)
      : '';

    if (entry && Number.isFinite(Number(entry.outputBytes)) && Number(entry.outputBytes) > 0) {
      track.dataset.audioSize = String(Math.max(0, Number(entry.outputBytes)));
    }

    if (cachedUrl) {
      track.dataset.audio = cachedUrl;
      if (sourceUrl) {
        track.dataset.audioFallback = sourceUrl;
      }
      return;
    }

    if (sourceUrl) {
      track.dataset.audio = sourceUrl;
      track.dataset.audioFallback = sourceUrl;
    }
  });
}

async function refreshServerCacheMapping(force) {
  const now = Date.now();
  if (!force && serverCacheMappingLoaded && (now - lastServerCacheRefreshAt) < SERVER_CACHE_REFRESH_INTERVAL_MS) {
    return serverCacheMappingAvailable;
  }

  if (serverCacheRefreshPromise) {
    return serverCacheRefreshPromise;
  }

  const mappingUrl = buildServerCacheMappingUrl();
  if (!mappingUrl) {
    serverCacheMappingLoaded = true;
    serverCacheMappingAvailable = false;
    lastServerCacheRefreshAt = now;
    return false;
  }

  serverCacheRefreshPromise = (async () => {
    try {
      const resp = await fetch(mappingUrl, {
        cache: 'no-store',
        credentials: 'same-origin'
      });

      if (!resp.ok) {
        serverCacheMappingLoaded = true;
        serverCacheMappingAvailable = false;
        // 隐患3修复：失败时不更新时间戳，允许快速重试
        // lastServerCacheRefreshAt = Date.now();
        return false;
      }

      const mappingEntries = await resp.json();
      applyServerCacheMapping(mappingEntries);
      serverCacheMappingLoaded = true;
      serverCacheMappingAvailable = Array.isArray(mappingEntries) && mappingEntries.length > 0;
      lastServerCacheRefreshAt = Date.now();
      return serverCacheMappingAvailable;
    } catch (_) {
      serverCacheMappingLoaded = true;
      serverCacheMappingAvailable = false;
      // 隐患3修复：失败时不更新时间戳，允许快速重试
      // lastServerCacheRefreshAt = Date.now();
      return false;
    } finally {
      serverCacheRefreshPromise = null;
    }
  })();

  return serverCacheRefreshPromise;
}

function getImmediateTrackPlaybackUrls(track) {
  const sourceUrl = toAbsoluteAudioUrl(getTrackSourceUrl(track));
  const directSourceUrl = toAbsoluteAudioUrl(ensureDirectPlayUrl(getTrackSourceUrl(track)));
  const currentUrl = track.dataset.audio || '';
  const preferredUrl = isServerCacheAudioUrl(currentUrl)
    ? toAbsoluteAudioUrl(currentUrl)
    : sourceUrl;
  return {
    preferredUrl: preferredUrl || sourceUrl,
    fallbackUrl: sourceUrl,
    directFallbackUrl: directSourceUrl || sourceUrl
  };
}
async function refreshOfflineDownloadState() {
  const playlistFileName = getCurrentPlaylistFileName();
  offlineDownloadState.playlistFileName = playlistFileName;
  if (!playlistFileName) {
    setOfflineStatus('无法识别歌单文件名', true);
    setDownloadButtonState(true);
    return;
  }

  setOfflineStatus('检查SSD转码状态中...', false);
  setDownloadButtonState(true);

  try {
    const endpoint = '/api/playlists/' + encodeURIComponent(playlistFileName) + '/offline-files';
    const resp = await fetch(endpoint, {
      credentials: 'same-origin',
      cache: 'no-store',
      headers: { Accept: 'application/json' }
    });
    const contentType = String(resp.headers.get('content-type') || '').toLowerCase();
    const payload = contentType.includes('application/json')
      ? await resp.json()
      : null;

    if (!resp.ok) {
      const errorCode = payload && payload.error ? String(payload.error) : '';
      const errorMessage = (payload && payload.message)
        || (errorCode === 'authentication_required' ? '离线下载接口需要登录，请先完成登录。' : '离线文件检查失败');
      setOfflineStatus(errorMessage, true);
      offlineDownloadState.ready = false;
      offlineDownloadState.files = [];
      return;
    }

    offlineDownloadState.ready = Boolean(payload && payload.ready);
    offlineDownloadState.files = Array.isArray(payload && payload.files) ? payload.files : [];

    if (!offlineDownloadState.ready) {
      setOfflineStatus((payload && payload.message) || '服务器正在预转码，请稍后重试', true);
      return;
    }

    setOfflineStatus('可下载离线音频 ' + offlineDownloadState.files.length + ' 首', false);
    setDownloadButtonState(offlineDownloadState.files.length === 0);
  } catch (_) {
    setOfflineStatus('离线文件检查失败，请稍后重试', true);
    offlineDownloadState.ready = false;
    offlineDownloadState.files = [];
  }
}

async function downloadOfflineFiles() {
  if (!offlineDownloadState.ready || !Array.isArray(offlineDownloadState.files) || offlineDownloadState.files.length === 0) {
    setOfflineStatus('离线音频未就绪，请稍后重试', true);
    return;
  }

  setDownloadButtonState(true);
  setOfflineStatus('开始下载离线音频，请允许浏览器多文件下载...', false);

  for (let i = 0; i < offlineDownloadState.files.length; i += 1) {
    const file = offlineDownloadState.files[i];
    if (!file || !file.downloadUrl) continue;
    const link = document.createElement('a');
    link.href = file.downloadUrl;
    link.download = file.fileName || '';
    link.style.display = 'none';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    await waitMs(180);
  }

  setOfflineStatus('离线音频下载任务已触发（共 ' + offlineDownloadState.files.length + ' 首）', false);
  setDownloadButtonState(false);
}

if (downloadOfflineBtn) {
  downloadOfflineBtn.addEventListener('click', () => {
    downloadOfflineFiles().catch(() => {
      setOfflineStatus('离线下载触发失败，请稍后重试', true);
      setDownloadButtonState(false);
    });
  });
}

async function refreshRuntimeState(forceRefresh) {
  try {
    await refreshServerCacheMapping(Boolean(forceRefresh));
  } catch (_) {}
  await refreshOfflineDownloadState();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => {
    refreshRuntimeState(false).catch(() => {});
  }, { once: true });
} else {
  refreshRuntimeState(false).catch(() => {});
}

document.addEventListener('visibilitychange', () => {
  if (!document.hidden) {
    refreshRuntimeState(true).catch(() => {});
  }
});

window.addEventListener('focus', () => {
  refreshRuntimeState(true).catch(() => {});
});
</script>
</body>
</html>`;
}

// CLI入口
if (require.main === module) {
  let theme = process.argv[2];
  const parsedCount = parseInt(process.argv[3], 10);
  const count = normalizePlaylistCount(parsedCount);

  // 支持 --vector / --hybrid / --keyword 参数切换搜索模式
  // 不传参数时使用 'auto'（读取 config.json 中 useVectorSearch 配置）
  // 用法示例：
  //   node scripts/generate-playlist.js "雨天发呆" 20 --vector
  //   node scripts/generate-playlist.js "雨天发呆" 20 --hybrid
  //   node scripts/generate-playlist.js "雨天发呆" 20           ← auto（读配置）
  const rawArgs = process.argv.slice(4);
  let searchMode = 'auto';
  if (rawArgs.includes('--vector')) searchMode = 'vector';
  else if (rawArgs.includes('--hybrid')) searchMode = 'hybrid';
  else if (rawArgs.includes('--keyword')) searchMode = 'keyword';

  if (!theme || theme.trim() === '') {
    theme = getSmartTheme();
  }

  generatePlaylist(theme, count, { searchMode }).then(result => {
    console.log(result.message);
    if (searchMode !== 'keyword') {
      console.log(`[搜索模式: ${result.searchMode || searchMode}]`);
    }
  }).catch(e => console.error('致命错误:', e));
}

module.exports = { generatePlaylist, chooseAutoTheme };

