function cleanMatchText(value) {
  return (value || '')
    .toString()
    .toLowerCase()
    .replace(/^[a-d]?\d{1,3}[.\-_\s]+/i, '')
    .replace(/[_]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

// 简繁体常见字映射（用于艺术家去重）
const SIMPLIFIED_MAP = {
  '傑': '杰', '倫': '伦', '華': '华', '國': '国', '東': '东', '風': '风',
  '愛': '爱', '樂': '乐', '學': '学', '書': '书', '電': '电', '車': '车',
