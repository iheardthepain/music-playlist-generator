{
  "server": {
    "port": 3000,
    "host": "0.0.0.0",
    "publicBaseUrl": "https://your-domain-or-ip"
  },
  "auth": {
    "enabled": true,
    "sessionDays": 7
  },
  "database": {
    "path": "data/index.db"
  },
  "musicLibrary": {
    "paths": [
      "/path/to/your/music",
      "/another/music/directory"
    ]
  },
  "playlist": {
    "defaultCount": 20,
    "maxCount": 50,
    "summaryCount": 20,
    "messageSummaryCount": 8,
    "useVectorSearch": false
  },
  "embedding": {
    "model": "your-embedding-model-id",
    "endpoint": "https://your-embedding-api-endpoint",
    "dim": 2048
  },
  "playback": {
    "transcodeToAac": false,
    "smartTranscodeLossless": true,
    "aacBitrate": "192k"
  }
}
